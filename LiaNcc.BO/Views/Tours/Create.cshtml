@model LiaNcc.BO.Models.Tours.TourViewModel
@{
    ViewData["Title"] = "Nuovo Tour";
}

<h2>Nuovo Tour</h2>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">Nome</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Slug" class="form-label">Slug (es. tour-matera)</label>
                    <input asp-for="Slug" class="form-control" />
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="CategoryId" class="form-label">Categoria</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="Model.AvailableCategories">
                        <option value="">Seleziona categoria</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Price" class="form-label">Prezzo (€)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="SortOrder" class="form-label">Ordine di visualizzazione</label>
                    <input asp-for="SortOrder" class="form-control" />
                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descrizione Breve</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>

            <hr />
            <h4>Cover & Hero Section</h4>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Cover Image</label>
                    <input type="file" name="CoverImageFile" class="form-control" accept="image/*" />
                    <input type="hidden" asp-for="CoverImageUrl" />
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="HeroTitle" class="form-label">Titolo Hero</label>
                        <input asp-for="HeroTitle" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="HeroSubtitle" class="form-label">Sottotitolo Hero</label>
                        <input asp-for="HeroSubtitle" class="form-control" />
                    </div>
                </div>
            </div>

            <hr />
            <h4>Esperienza</h4>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Experience Image</label>
                    <input type="file" name="ExperienceImageFile" class="form-control" accept="image/*" />
                    <input type="hidden" asp-for="ExperienceImageUrl" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ExperienceDescription" class="form-label">Descrizione Esperienza</label>
                    <textarea asp-for="ExperienceDescription" class="form-control" rows="4"></textarea>
                </div>
            </div>

            <hr />
            <h4>Dettagli Viaggio</h4>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="DurationDays" class="form-label">Durata (Giorni)</label>
                    <input asp-for="DurationDays" type="number" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="DurationHours" class="form-label">Durata (Ore)</label>
                    <input asp-for="DurationHours" type="number" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="MeetingPoint" class="form-label">Punto di Ritrovo</label>
                    <input asp-for="MeetingPoint" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="VehicleId" class="form-label">Veicolo Predefinito</label>
                    <select asp-for="VehicleId" class="form-select" asp-items="Model.AvailableVehicles">
                        <option value="">Nessun veicolo predefinito</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3 pt-4 form-check ms-3">
                    <input asp-for="IsFeatured" class="form-check-input" />
                    <label asp-for="IsFeatured" class="form-check-label">In Evidenza</label>
                </div>
                <div class="col-md-2 mb-3 pt-4 form-check ms-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Attivo</label>
                </div>
            </div>

            <partial name="_LocalizationFields" model="Model.Translations" />

            <div class="mt-4">
                <button type="submit" class="btn btn-gold">Crea Tour</button>
                <a asp-action="Index" class="btn btn-secondary">Annulla</a>
            </div>
        </form>
    </div>
</div>
