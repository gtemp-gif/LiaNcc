@model IEnumerable<LiaNcc.Models.Entities.Tour>
@{
    ViewData["Title"] = "Gestione Tour";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Tour</h2>
    <a asp-action="Create" class="btn btn-gold"><i class="bi bi-plus-circle"></i> Nuovo Tour</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Slug</th>
                        <th>Prezzo</th>
                        <th>In Evidenza</th>
                        <th>Stato</th>
                        <th>Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Slug</td>
                                <td>@(item.Price.HasValue ? item.Price.Value.ToString("C") : "N/D")</td>
                                <td>
                                    @if(item.IsFeatured)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Sì</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Attivo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inattivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Sei sicuro di voler eliminare questo tour?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="6" class="text-center text-muted py-4">Nessun tour presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
