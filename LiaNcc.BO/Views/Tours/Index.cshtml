@model IEnumerable<LiaNcc.Models.DTOs.Tours.TourDto>
@{
    ViewData["Title"] = "Gestione Tours";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Tours</h2>
    <a asp-action="Create" class="btn btn-gold"><span class="material-symbols-outlined">add_circle</span> Nuovo Tour</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Cover</th>
                        <th>Nome</th>
                        <th>Slug</th>
                        <th>Prezzo</th>
                        <th>Veicolo</th>
                        <th>In Evidenza</th>
                        <th>Stato</th>
                        <th>Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@MediaUrlHelper.GetAbsoluteUrl(item.CoverImageUrl)" alt="Cover" class="img-thumbnail" style="max-width: 80px;" />
                                }
                                else
                                {
                                    <span class="text-muted small">No image</span>
                                }
                            </td>
                            <td>@item.Name</td>
                            <td><small>@item.Slug</small></td>
                            <td>@(item.Price.HasValue ? item.Price.Value.ToString("C") : "-")</td>
                            <td><small>@item.VehicleName</small></td>
                            <td>
                                @if (item.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark"><span class="material-symbols-outlined" style="font-size: 14px;">star</span> Sì</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Attivo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inattivo</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><span class="material-symbols-outlined">edit</span></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Sei sicuro di voler eliminare questo tour?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><span class="material-symbols-outlined">delete</span></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
