@model IEnumerable<LiaNcc.Models.Entities.Booking>
@{
    ViewData["Title"] = "Gestione Prenotazioni";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Prenotazioni</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Richiedente</th>
                        <th>Email / Telefono</th>
                        <th>Data Servizio</th>
                        <th>Stato</th>
                        <th>Data Richiesta</th>
                        <th style="width: 150px;">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>
                                    <div>@item.Email</div>
                                    @if(!string.IsNullOrEmpty(item.Phone)) {
                                        <small class="text-muted">@item.Phone</small>
                                    }
                                </td>
                                <td>@item.ServiceDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if(item.Status == "Pending") {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    } else if (item.Status == "Confirmed") {
                                        <span class="badge bg-success">Confermata</span>
                                    } else {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        @if (item.Status == "Pending")
                                        {
                                            <form asp-action="UpdateStatus" asp-route-id="@item.Id" asp-route-status="Confirmed" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-success" title="Conferma">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                            <form asp-action="UpdateStatus" asp-route-id="@item.Id" asp-route-status="Cancelled" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger" title="Annulla">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminare questa prenotazione?')">
                                            <button type="submit" class="btn btn-outline-dark" title="Elimina">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="5" class="text-center text-muted py-4">Nessuna prenotazione presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
