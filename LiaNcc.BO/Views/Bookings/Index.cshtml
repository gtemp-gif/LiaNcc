@using System.Text.Json
@using System.Text.Json.Serialization
@model IEnumerable<LiaNcc.Models.DTOs.Responses.BookingDetailDto>
@{
    ViewData["Title"] = "Gestione Prenotazioni";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Prenotazioni</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Richiedente</th>
                        <th>Servizio / Tour / Veicolo</th>
                        <th>Data Servizio</th>
                        <th>Stato</th>
                        <th>Provenienza</th>
                        <th>Data Richiesta</th>
                        <th class="text-end pe-3">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <strong>@item.FullName</strong>
                                    <div class="small text-muted">@item.Email</div>
                                    @if(!string.IsNullOrEmpty(item.Phone)) {
                                        <small class="text-muted"><i class="bi bi-telephone me-1"></i>@item.Phone</small>
                                    }
                                </td>
                                <td>
                                    @if (item.TourId.HasValue)
                                    {
                                        <span class="badge bg-primary">Tour</span>
                                        <small class="d-block">@item.TourName</small>
                                    }
                                    else if (item.VehicleId.HasValue)
                                    {
                                        <span class="badge bg-dark">Flotta</span>
                                        <small class="d-block">@item.VehicleName @(!string.IsNullOrEmpty(item.VehicleCategoryName) ? $"({item.VehicleCategoryName})" : "")</small>
                                    }
                                    else if (item.ServiceTypeId.HasValue)
                                    {
                                        <span class="badge bg-info text-dark">Servizio</span>
                                        <small class="d-block">@item.ServiceTypeName</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted italic small">Non specificato</span>
                                    }
                                </td>
                                <td>
                                    <strong>@item.ServiceDate.ToDisplayString(false)</strong>
                                    <small class="d-block text-muted">@item.ServiceDate.ToRomeTime().ToString("HH:mm")</small>
                                </td>
                                <td>
                                    @if(item.Status == "Pending") {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    } else if (item.Status == "Confirmed") {
                                        <span class="badge bg-success">Confermata</span>
                                    } else if (item.Status == "Cancelled") {
                                        <span class="badge bg-danger">Annullata</span>
                                    } else {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    @if(!string.IsNullOrEmpty(item.SourcePage)) {
                                        <span class="badge bg-light text-dark border">@item.SourcePage</span>
                                    } else {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToDisplayString()</td>
                                <td class="text-end pe-3">
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-primary" title="Dettagli"
                                                onclick='showBookingDetails(@JsonSerializer.Serialize(item, new JsonSerializerOptions { ReferenceHandler = ReferenceHandler.IgnoreCycles }))'>
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (item.Status == "Pending")
                                        {
                                            <form asp-action="UpdateStatus" asp-route-id="@item.Id" asp-route-status="Confirmed" method="post" class="d-inline" onsubmit="return confirm('Confermare questa prenotazione? Verrà inviata una mail al cliente.')">
                                                <button type="submit" class="btn btn-outline-success" title="Conferma">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-outline-danger" title="Rifiuta"
                                                    onclick="openRejectModal('@item.Id')">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminare questa prenotazione?')">
                                            <button type="submit" class="btn btn-outline-dark" title="Elimina">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="6" class="text-center text-muted py-5">Nessuna prenotazione presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Rifiuto -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="id" id="reject-booking-id" />
                <input type="hidden" name="status" value="Cancelled" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Rifiuta Prenotazione</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Inserisci la motivazione del rifiuto. Questa verrà inviata via email al cliente.</p>
                    <div class="form-group">
                        <label class="form-label">Motivazione</label>
                        <textarea name="note" class="form-control" rows="4" required placeholder="Es: Purtroppo non abbiamo disponibilità per la data richiesta..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                    <button type="submit" class="btn btn-danger">Invia Rifiuto</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Dettaglio -->
<div class="modal fade" id="bookingDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Dettaglio Prenotazione</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3 border-bottom pb-2">Informazioni Cliente</h6>
                        <table class="table table-sm table-borderless">
                            <tr><th>Nome</th><td id="det-name"></td></tr>
                            <tr><th>Email</th><td id="det-email"></td></tr>
                            <tr><th>Telefono</th><td id="det-phone"></td></tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3 border-bottom pb-2">Stato e Date</h6>
                        <table class="table table-sm table-borderless">
                            <tr><th>Stato</th><td id="det-status-badge"></td></tr>
                            <tr><th>Data Servizio</th><td id="det-service-date"></td></tr>
                            <tr><th>Richiesta il</th><td id="det-created-at"></td></tr>
                        </table>
                    </div>
                    <div class="col-12">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3 border-bottom pb-2">Dettagli Servizio</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="text-muted small d-block">Tipo / Origine</label>
                                <span id="det-origin" class="fw-bold"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="text-muted small d-block">Provenienza</label>
                                <span id="det-source-page" class="fw-bold"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="text-muted small d-block">Specifiche</label>
                                <span id="det-specs" class="fw-bold text-primary"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="text-muted small d-block">Passeggeri</label>
                                <span id="det-passengers"></span>
                            </div>
                            <div class="col-md-8">
                                <label class="text-muted small d-block">Opzione Passeggeri</label>
                                <span id="det-passenger-opt"></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3 border-bottom pb-2">Messaggio del Cliente</h6>
                        <div class="p-3 bg-light rounded italic" id="det-message"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Chiudi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRejectModal(bookingId) {
            document.getElementById('reject-booking-id').value = bookingId;
            const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
            modal.show();
        }

        function showBookingDetails(booking) {
            document.getElementById('det-name').innerText = booking.FullName;
            document.getElementById('det-email').innerText = booking.Email;
            document.getElementById('det-phone').innerText = booking.Phone || '-';
            document.getElementById('det-service-date').innerText = formatRomeDate(booking.ServiceDate);
            document.getElementById('det-created-at').innerText = formatRomeDate(booking.CreatedAt);
            document.getElementById('det-passengers').innerText = booking.MaxSeats || '1';
            document.getElementById('det-message').innerText = booking.Message || 'Nessun messaggio fornito.';

            // Badge Stato
            let badge = document.getElementById('det-status-badge');
            badge.className = 'badge ';
            if (booking.Status === 'Pending') {
                badge.className += 'bg-warning text-dark';
                badge.innerText = 'Pending';
            } else if (booking.Status === 'Confirmed') {
                badge.className += 'bg-success';
                badge.innerText = 'Confermata';
            } else if (booking.Status === 'Cancelled') {
                badge.className += 'bg-danger';
                badge.innerText = 'Annullata';
            } else {
                badge.className += 'bg-secondary';
                badge.innerText = booking.Status;
            }

            // Origine
            let origin = document.getElementById('det-origin');
            let specs = document.getElementById('det-specs');
            document.getElementById('det-source-page').innerText = booking.SourcePage || '-';

            if (booking.TourId) {
                origin.innerHTML = '<span class="badge bg-primary">Tour</span>';
                specs.innerText = booking.TourName;
            } else if (booking.VehicleId) {
                origin.innerHTML = '<span class="badge bg-dark">Flotta</span>';
                specs.innerText = booking.VehicleName + (booking.VehicleCategoryName ? ' (' + booking.VehicleCategoryName + ')' : '');
            } else if (booking.ServiceTypeId) {
                origin.innerHTML = '<span class="badge bg-info text-dark">Servizio</span>';
                specs.innerText = booking.ServiceTypeName;
            } else {
                origin.innerText = 'Non specificato';
                specs.innerText = '-';
            }

            document.getElementById('det-passenger-opt').innerText = booking.PassengerOptionName || '-';

            const modal = new bootstrap.Modal(document.getElementById('bookingDetailModal'));
            modal.show();
        }
    </script>
}
