@model LiaNcc.Models.Entities.Service
@{
    ViewData["Title"] = "Modifica Servizio";
}

<h2>Modifica Servizio</h2>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">Nome</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Icon" class="form-label">Icona (es. bi-car)</label>
                    <input asp-for="Icon" class="form-control" />
                    <span asp-validation-for="Icon" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Immagine di Copertina</label>
                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.CoverImageUrl" alt="Cover Preview" class="img-thumbnail" style="max-height: 150px;" />
                        </div>
                    }
                    <input type="file" name="coverImageFile" class="form-control" accept="image/*" />
                    <input type="hidden" asp-for="CoverImageUrl" />
                    <small class="text-muted">Lascia vuoto per mantenere l'immagine attuale.</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SortOrder" class="form-label">Ordine di visualizzazione</label>
                    <input asp-for="SortOrder" class="form-control" />
                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3 form-check ms-3">
                    <input asp-for="IsFeatured" class="form-check-input" />
                    <label asp-for="IsFeatured" class="form-check-label">In Evidenza</label>
                </div>
                <div class="col-md-4 mb-3 form-check ms-3">
                    <input asp-for="IsBookable" class="form-check-input" />
                    <label asp-for="IsBookable" class="form-check-label">Prenotabile</label>
                </div>
                <div class="col-md-3 mb-3 form-check ms-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Attivo</label>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-gold">Salva Modifiche</button>
                <a asp-action="Index" class="btn btn-secondary">Annulla</a>
            </div>
        </form>
    </div>
</div>
