@model IEnumerable<LiaNcc.Models.Entities.Service>
@{
    ViewData["Title"] = "Gestione Servizi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Servizi</h2>
    <a asp-action="Create" class="btn btn-gold"><i class="bi bi-plus-circle"></i> Nuovo Servizio</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Cover</th>
                        <th>Nome</th>
                        <th>Icona</th>
                        <th>In Evidenza</th>
                        <th>Prenotabile</th>
                        <th>Stato</th>
                        <th>Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                {
                                    <img src="@MediaUrlHelper.GetAbsoluteUrl(item.CoverImageUrl)" alt="Cover" class="img-thumbnail" style="max-width: 80px;" />
                                }
                                else
                                {
                                    <span class="text-muted small">No image</span>
                                }
                            </td>
                            <td>@item.Name</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Icon))
                                {
                                    <span class="material-symbols-outlined">@item.Icon</span>
                                    <small class="text-muted">@item.Icon</small>
                                }
                            </td>
                            <td>
                                @if(item.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Sì</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.IsBookable)
                                {
                                    <span class="badge bg-info text-dark">Sì</span>
                                }
                                else
                                {
                                    <span class="text-muted">No</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Attivo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inattivo</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Sei sicuro di voler eliminare questo servizio?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
