@model IEnumerable<LiaNcc.Models.Entities.ContactMessage>
@{
    ViewData["Title"] = "Gestione Messaggi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Messaggi</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Messaggio</th>
                        <th>Letto</th>
                        <th>Data</th>
                        <th style="width: 100px;">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr class="@(item.IsRead ? "" : "fw-bold")">
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td class="text-truncate" style="max-width: 300px;" title="@item.Message">@item.Message</td>
                                <td>
                                    @if(item.IsRead) {
                                        <i class="bi bi-envelope-open text-muted"></i>
                                    } else {
                                        <i class="bi bi-envelope-fill text-primary"></i>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        @if (!item.IsRead)
                                        {
                                            <form asp-action="MarkAsRead" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-outline-success" title="Segna come letto">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Eliminare questo messaggio?')">
                                            <button type="submit" class="btn btn-outline-danger" title="Elimina">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="5" class="text-center text-muted py-4">Nessun messaggio presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
