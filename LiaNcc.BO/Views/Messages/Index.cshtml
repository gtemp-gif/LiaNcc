@using System.Text.Json
@model IEnumerable<LiaNcc.Models.Entities.ContactMessage>
@{
    ViewData["Title"] = "Gestione Messaggi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Messaggi</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3">Stato</th>
                        <th>Mittente</th>
                        <th>Messaggio</th>
                        <th>Data Ricezione</th>
                        <th class="text-end pe-3">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr class="@(item.IsRead ? "text-muted" : "table-info fw-bold")" style="cursor: pointer;"
                                data-message='@JsonSerializer.Serialize(item)'>
                                <td class="ps-3" onclick='showMessageDetails(this.closest("tr").dataset.message)'>
                                    @if(item.IsRead) {
                                        <i class="bi bi-envelope-open fs-5"></i>
                                    } else {
                                        <i class="bi bi-envelope-fill text-primary fs-5"></i>
                                    }
                                </td>
                                <td onclick='showMessageDetails(this.closest("tr").dataset.message)'>
                                    <div>@item.FullName</div>
                                    <small class="text-muted">@item.Email</small>
                                </td>
                                <td onclick='showMessageDetails(this.closest("tr").dataset.message)'>
                                    <div class="text-truncate" style="max-width: 400px;">@item.Message</div>
                                </td>
                                <td onclick='showMessageDetails(this.closest("tr").dataset.message)'>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end pe-3">
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-primary" title="Leggi"
                                                onclick='showMessageDetails(this.closest("tr").dataset.message)'>
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-info" title="Rispondi"
                                                onclick='openReplyModal(this.closest("tr").dataset.message)'>
                                            <i class="bi bi-reply"></i>
                                        </button>
                                        @if (!item.IsRead)
                                        {
                                            <form asp-action="MarkAsRead" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-success" title="Segna come letto">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminare questo messaggio?')">
                                            <button type="submit" class="btn btn-outline-danger" title="Elimina">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="5" class="text-center text-muted py-5">Nessun messaggio presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Rispondi Messaggio -->
<div class="modal fade" id="replyMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <form asp-action="Reply" method="post" enctype="multipart/form-data">
                <input type="hidden" name="id" id="reply-msg-id" />
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-reply me-2"></i>Rispondi al Messaggio</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="text-muted small d-block">A:</label>
                        <strong id="reply-msg-to"></strong>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Oggetto</label>
                        <input type="text" name="subject" id="reply-msg-subject" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Messaggio</label>
                        <textarea name="body" class="form-control" rows="10" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Allegati</label>
                        <input type="file" name="attachments" class="form-control" multiple />
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                    <button type="submit" class="btn btn-info text-white">Invia Risposta</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Dettaglio Messaggio -->
<div class="modal fade" id="messageDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-envelope me-2"></i>Dettaglio Messaggio</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-4">
                    <label class="text-muted small d-block">Da:</label>
                    <strong id="det-msg-name" class="fs-5"></strong>
                    <div id="det-msg-email" class="text-primary"></div>
                </div>
                <div class="mb-4">
                    <label class="text-muted small d-block">Ricevuto il:</label>
                    <span id="det-msg-date"></span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block mb-1">Contenuto del messaggio:</label>
                    <div class="p-3 bg-light rounded border" id="det-msg-content" style="white-space: pre-wrap; min-height: 100px;"></div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <div id="mark-as-read-footer" class="me-auto">
                    <form asp-action="MarkAsRead" method="post" id="form-mark-read">
                        <input type="hidden" name="id" id="det-msg-id" />
                        <button type="submit" class="btn btn-sm btn-success">Segna come letto</button>
                    </form>
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Chiudi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openReplyModal(msgData) {
            const msg = typeof msgData === 'string' ? JSON.parse(msgData) : msgData;
            document.getElementById('reply-msg-id').value = msg.Id;
            document.getElementById('reply-msg-to').innerText = msg.FullName + " (" + msg.Email + ")";
            document.getElementById('reply-msg-subject').value = "Re: " + msg.Message.substring(0, 50) + (msg.Message.length > 50 ? "..." : "");

            const modal = new bootstrap.Modal(document.getElementById('replyMessageModal'));
            modal.show();
        }

        function showMessageDetails(msgData) {
            const msg = typeof msgData === 'string' ? JSON.parse(msgData) : msgData;
            document.getElementById('det-msg-name').innerText = msg.FullName;
            document.getElementById('det-msg-email').innerText = msg.Email;
            document.getElementById('det-msg-date').innerText = new Date(msg.CreatedAt).toLocaleString();
            document.getElementById('det-msg-content').innerText = msg.Message;
            document.getElementById('det-msg-id').value = msg.Id;

            if (msg.IsRead) {
                document.getElementById('mark-as-read-footer').style.display = 'none';
            } else {
                document.getElementById('mark-as-read-footer').style.display = 'block';
            }

            const modal = new bootstrap.Modal(document.getElementById('messageDetailModal'));
            modal.show();
        }
    </script>
}
