<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LiaNcc BackOffice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        :root {
            --primary-gold: #D4AF37;
            --primary-dark: #1A1A1A;
            --sidebar-width: 250px;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Sidebar styling */
        #sidebar {
            width: var(--sidebar-width);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            background-color: #ffffff;
            border-right: 1px solid #e0e0e0;
            z-index: 1000;
            padding-top: 60px; /* Space for topbar */
            overflow-y: auto;
        }

        #sidebar .nav-link {
            color: #495057;
            padding: 10px 20px;
            font-weight: 500;
        }

        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            color: var(--primary-gold);
            background-color: rgba(212, 175, 55, 0.1);
            border-left: 3px solid var(--primary-gold);
        }

        /* Topbar styling */
        #topbar {
            position: fixed;
            top: 0;
            right: 0;
            left: 0;
            height: 60px;
            background-color: var(--primary-dark);
            color: white;
            z-index: 1030;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
        }

        #topbar .brand {
            color: var(--primary-gold);
            font-weight: bold;
            font-size: 1.2rem;
            text-decoration: none;
            width: calc(var(--sidebar-width) - 20px);
        }

        /* Main content styling */
        #main-content {
            margin-left: var(--sidebar-width);
            padding-top: 60px;
            min-height: 100vh;
        }

        .content-wrapper {
            padding: 20px;
        }

        /* Utils */
        .btn-gold {
            background-color: var(--primary-gold);
            color: white;
            border: none;
        }
        .btn-gold:hover {
            background-color: #b5952f;
            color: white;
        }

        .card-stat {
            border-left: 4px solid var(--primary-gold);
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }

        .material-symbols-outlined {
            font-family: 'Material Symbols Outlined';
            font-weight: normal;
            font-style: normal;
            font-size: 22px;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
            vertical-align: middle;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Topbar -->
    <header id="topbar">
        <a href="/" class="brand">Lia NCC BO</a>

        <div class="user-menu dropdown">
            <a href="#" class="text-white text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="dropdown-item">Logout</button>
                    </form>
                </li>
            </ul>
        </div>
    </header>

    <!-- Sidebar -->
    <nav id="sidebar">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>

            <li class="nav-item mt-3 px-3 text-muted text-uppercase" style="font-size: 0.8rem;">Contenuti</li>
            <li class="nav-item"><a class="nav-link" asp-controller="CMS" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i> CMS</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Services" asp-action="Index"><i class="bi bi-briefcase me-2"></i> Servizi</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Vehicles" asp-action="Index"><i class="bi bi-car-front me-2"></i> Flotta</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Tours" asp-action="Index"><i class="bi bi-map me-2"></i> Tour</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Media" asp-action="Index"><i class="bi bi-images me-2"></i> Media</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Localization" asp-action="Index"><i class="bi bi-translate me-2"></i> Localizzazione</a></li>

            <li class="nav-item mt-3 px-3 text-muted text-uppercase" style="font-size: 0.8rem;">Operazioni</li>
            <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="Index"><i class="bi bi-calendar-check me-2"></i> Prenotazioni</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Messages" asp-action="Index"><i class="bi bi-envelope me-2"></i> Messaggi</a></li>

            <li class="nav-item mt-3 px-3 text-muted text-uppercase" style="font-size: 0.8rem;">Impostazioni</li>
            <li class="nav-item"><a class="nav-link" asp-controller="Company" asp-action="Index"><i class="bi bi-building me-2"></i> Azienda</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Partners" asp-action="Index"><i class="bi bi-people me-2"></i> Partner</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index"><i class="bi bi-person-badge me-2"></i> Utenti</a></li>
            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Logs" ? "active" : "")" asp-controller="Logs" asp-action="Index"><i class="bi bi-list-columns-reverse me-2"></i> Log di sistema</a></li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main id="main-content">
        <div class="content-wrapper">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
