@model IEnumerable<LiaNcc.Models.Entities.MediaAsset>
@{
    ViewData["Title"] = "Gestione Media";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Media</h2>
    <form asp-action="Upload" method="post" enctype="multipart/form-data" class="d-flex align-items-center">
        <input type="file" name="file" class="form-control me-2" required />
        <button type="submit" class="btn btn-gold"><i class="bi bi-upload"></i> Upload</button>
    </form>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (item.MimeType.StartsWith("image/"))
                {
                    <img src="@item.FileUrl" class="card-img-top" alt="@item.FileName" style="height: 150px; object-fit: cover;" />
                }
                else
                {
                    <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 150px;">
                        <i class="bi bi-file-earmark fs-1 text-muted"></i>
                    </div>
                }
                <div class="card-body">
                    <h6 class="card-title text-truncate" title="@item.FileName">@item.FileName</h6>
                    <small class="text-muted d-block">@item.MimeType</small>
                    <small class="text-muted">@((item.FileSize / 1024.0).ToString("0.00")) KB</small>
                </div>
                <div class="card-footer bg-transparent border-top-0 text-end">
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Sei sicuro di voler eliminare questo file?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Elimina</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
