@model IEnumerable<LiaNcc.Models.Entities.SitePage>
@{
    ViewData["Title"] = "Gestione CMS";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Pagine Sito (CMS)</h2>
    <a asp-action="Create" class="btn btn-gold"><i class="bi bi-plus-circle"></i> Nuova Pagina</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Slug</th>
                        <th>Stato</th>
                        <th>Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Slug</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Attivo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inattivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="3" class="text-center text-muted py-4">Nessuna pagina presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
