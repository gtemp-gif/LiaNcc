@model IEnumerable<LiaNcc.Models.Entities.Partner>
@{
    ViewData["Title"] = "Gestione Partner";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestione Partner</h2>
    <a asp-action="Create" class="btn btn-gold"><span class="material-symbols-outlined">add_circle</span> Nuovo Partner</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Website</th>
                        <th>Stato</th>
                        <th>Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any()) {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td><a href="@item.WebsiteUrl" target="_blank">@item.WebsiteUrl</a></td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Attivo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inattivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><span class="material-symbols-outlined">edit</span></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminare questo partner?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><span class="material-symbols-outlined">edit</span></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="4" class="text-center text-muted py-4">Nessun partner presente.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
