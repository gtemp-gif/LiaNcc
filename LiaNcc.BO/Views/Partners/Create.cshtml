@model LiaNcc.Models.Entities.Partner
@{
    ViewData["Title"] = "Nuovo Partner";
}

<h2>@ViewData["Title"]</h2>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nome</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WebsiteUrl" class="form-label">Sito Web URL</label>
                <input asp-for="WebsiteUrl" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="LogoUrl" class="form-label">Logo URL</label>
                <input asp-for="LogoUrl" class="form-control" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SortOrder" class="form-label">Ordine di visualizzazione</label>
                    <input asp-for="SortOrder" class="form-control" />
                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3 form-check ms-3 mt-4">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Attivo</label>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-gold">Salva</button>
                <a asp-action="Index" class="btn btn-secondary">Annulla</a>
            </div>
        </form>
    </div>
</div>
