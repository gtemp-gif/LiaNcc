                <img alt="Detail of luxury car interior" class="w-full h-full object-cover hover:scale-105 transition-all duration-1000" src="https://lh3.googleusercontent.com/aida-public/AB6AXuArenUbClj6Ny8UzjJ6FfcYPDx11ecqRNAGQGxuM1Zpdud6udYLP8l0E57033phzoNKqcQJylSV170bO40btj-eMuCGMIRMsnRl3t7s4an1YEt9CqOD9x50WDxajtijmM7ecstCciqO4YZIO42PxCAfAkXjs8mgOBILWtE-adXbayUmYmPYh3VIqvYS45aN-3i2Vac-iuQ2ctCDqfnl2S3PD-SqT8Jmz-XAomtngsbID3Fc0bHTp19IWrIayjeRhzJCM82kKIF4VYtl" />
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-10">
                    <span class="text-[10px] font-bold text-[#D4AF37] tracking-[0.4em] uppercase">Comfort Assoluto</span>
                </div>
            </div>
            <div class="md:col-span-4 relative overflow-hidden charcoal-border group">
                <img alt="Calanchi landscape Basilicata" class="w-full h-full object-cover hover:scale-105 transition-all duration-1000" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAbsKDedGDxegJMpkz7iD1QujfTHKsmVwxHxCPVGYn-TCXTOQY21LtK5G1eOyKjjSKol_npeS_VUUDjiRFwDdntYF5bEmXahPZ_xrQjNYPOfLOYjMTZcFtQQdy934K4ViID8XJFg6HCwSJaO92bhpTaZbhd7tW2SfgB1gshv7MLEeIuhWevyP1yIsxf-5cP8-wGdvg-fP3IYcPyjmf4d685CxESy3AvaIMmkHhEjgiE2Riiv9jxnf0PogoynbjtVnslgAwkduQ8Tw14" />
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-10">
                    <span class="text-[10px] font-bold text-[#D4AF37] tracking-[0.4em] uppercase">Materia Lunare</span>
                </div>
            </div>
            <div class="md:col-span-8 relative overflow-hidden charcoal-border group">
                <img alt="Luxury car in landscape" class="w-full h-full object-cover hover:scale-105 transition-all duration-1000" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBY4grWgxUnEMErnswPU4YD3n9ecFzz8EdIimWB4Ai5ukezUEEpYtoyckHuUh5u6jWVwKpLWZtr-v2HIHSr16jWyWZtpwUL0YWJCARONY-JNL-jjOuZ8XpZdwcfEcQobzXt0PhsfWmIguT_h6sPlBJDCNGkjbfPO6zNSULI1cp7Gcs2EwlMCKHACxCvqAwuLJNvAxUPvdATC92zde3J10Vgs-iXKo-9_e5qrykkypfvkbgY5daff7fl9M7ShfEdbcEzZ39ZL6T1VIza" />
