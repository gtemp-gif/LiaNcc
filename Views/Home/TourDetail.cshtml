    <!-- Dettagli del Viaggio -->
    <section class="py-32">
        <div class="text-left mb-16">
            <h2 class="text-4xl font-semibold text-white section-title text-[24px]">Dettagli del Viaggio</h2>
            <div class="w-16 h-1 bg-[#D4AF37] mt-4"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
            <div class="p-10 charcoal-border bg-black text-center space-y-6 hover:border-[#D4AF37] transition-all duration-500">
                <span class="material-symbols-outlined text-[#D4AF37] text-5xl">schedule</span>
                <h3 class="text-[10px] font-bold text-white uppercase tracking-[0.3em]">Durata</h3>
                <p class="text-gray-400 font-light text-[15px]">8 Ore / Intera Giornata</p>
            </div>
            <div class="p-10 charcoal-border bg-black text-center space-y-6 hover:border-[#D4AF37] transition-all duration-500">
                <span class="material-symbols-outlined text-[#D4AF37] text-5xl">location_on</span>
                <h3 class="text-[10px] font-bold text-white uppercase tracking-[0.3em]">Meeting Point</h3>
                <p class="text-gray-400 font-light text-[15px]">Pick-up presso Hotel o Residenza Privata</p>
            </div>
            <div class="p-10 charcoal-border bg-black text-center space-y-6 hover:border-[#D4AF37] transition-all duration-500">
                <span class="material-symbols-outlined text-[#D4AF37] text-5xl">directions_car</span>
                <h3 class="text-[10px] font-bold text-white uppercase tracking-[0.3em]">Veicoli</h3>
                <p class="text-gray-400 font-light text-[15px]">Mercedes-Benz Classe S o V-Class Luxury</p>
            </div>
        </div>
    </section>
    <!-- Richiesta Prenotazione -->
    <section class="py-32" id="reservations">
        <div class="max-w-4xl mx-auto">
            <div class="text-left mb-12">
                <h2 class="text-4xl font-semibold text-white mb-4 section-title text-[24px]">Richiesta Prenotazione VIP</h2>
                <p class="text-gray-400 font-light text-[15px]">Compila il modulo per ricevere un preventivo personalizzato immediato.</p>
            </div>
            <div class="bg-black p-8 md:p-20 relative charcoal-border">
                <form class="space-y-12">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-2">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
                            <input class="w-full input-underline text-white py-4 font-light text-[15px]" placeholder="Mario Rossi" type="text" />
                        </div>
                        <div class="space-y-2">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
                            <input class="w-full input-underline text-white py-4 font-light text-[15px]" placeholder="mario@esempio.it" type="email" />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-2">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data Desiderata</label>
                            <input class="w-full input-underline text-white py-4 font-light text-[15px] [color-scheme:dark]" type="date" />
                        </div>
                        <div class="space-y-2">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Numero Ospiti</label>
                            <select class="w-full input-underline text-white py-4 font-light text-[15px] appearance-none cursor-pointer">
                                <option class="bg-black">1 - 2 Persone</option>
                                <option class="bg-black">3 - 5 Persone</option>
                                <option class="bg-black">Privato Exclusive</option>
                            </select>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Note Aggiuntive (Discrezione Garantita)</label>
                        <textarea class="w-full input-underline text-white py-4 font-light text-[15px] resize-none" placeholder="Indica eventuali richieste particolari..." rows="3"></textarea>
                    </div>
                    <button class="w-full py-6 gold-bg text-black font-bold uppercase text-[12px] tracking-[0.3em] hover:bg-[#E5C158] transition-all" type="submit">Invia Richiesta di Prenotazione</button>
                </form>
            </div>
        </div>
    </section>
</main>
