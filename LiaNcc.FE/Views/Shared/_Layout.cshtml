    <style>
        body {
        background-color: #000000;
        color: #e2e2e2;
        font-family: 'Montserrat', sans-serif;
        font-weight: 400;
        }

        h1, h2, h3 {
        font-weight: 600;
        }

        .section-title {
        text-transform: uppercase;
        letter-spacing: 3px;
        }

        .light-text {
        font-weight: 300;
        }

        .gold-border {
        border: 1px solid #D4AF37;
        }

        .gold-text {
        color: #D4AF37;
        }

        .gold-bg {
        background-color: #D4AF37;
        }

        .charcoal-border {
        border: 1px solid #1A1A1A;
        }

        .glass-effect {
        backdrop-filter: blur(20px);
        background: rgba(0, 0, 0, 0.7);
        }

        .hero-mask {
        background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.9) 100%);
        }

        .cinematic-img {
        filter: grayscale(20%) contrast(110%);
        }

        .modal-overlay {
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(10px);
        }

        .btn-secondary {
        background-color: transparent;
        border: 1px solid #D4AF37;
        color: #D4AF37;
        font-family: 'Montserrat', sans-serif;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 12px 32px;
        white-space: nowrap;
        transition: all 0.4s ease;
        display: inline-block;
        text-align: center;
        }

        .btn-secondary:hover {
        background-color: #D4AF37;
        color: #121212;
        }

        .input-underline {
        border: none;
        border-bottom: 1px solid #1A1A1A;
        background: transparent !important;
        transition: border-color 0.4s ease;
        }

        .input-underline:focus {
        outline: none;
        border-bottom: 1px solid #D4AF37;
        box-shadow: none;
        ring: 0;
        }

        .btn-ghost {
        background-color: transparent;
        border: 1px solid #D4AF37;
        color: #D4AF37;
        font-family: 'Montserrat', sans-serif;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 12px 32px;
        white-space: nowrap;
        transition: all 0.4s ease;
        display: inline-block;
        text-align: center;
        }

        .btn-ghost:hover {
        background-color: #D4AF37;
        color: #000000;
        }

        .luxury-gradient-bg {
        background: radial-gradient(circle at 50% -20%, #1A1A1A 0%, #000000 100%);
        }

        .vehicle-glow {
        filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.15));
        }

        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .noir-gradient {
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 40%, rgba(0,0,0,0) 100%);
