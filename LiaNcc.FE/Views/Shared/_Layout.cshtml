<!DOCTYPE html>
<html class="dark scroll-smooth" lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LIA NCC</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: {
                            DEFAULT: "#D4AF37", // Oro caldo
                            dark: "#B8860B" // Oro scuro
                        },
                        on: {
                            primary: "#000000",
                            surface: "#FFFFFF",
                            "surface-variant": "#9CA3AF"
                        }
                    },
                    fontFamily: {
                        sans: ['Montserrat', 'sans-serif'],
                        display: ['Montserrat', 'sans-serif'],
                        body: ['Montserrat', 'sans-serif'],
                    }
                }
            }
        };
    </script>
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #000000;
            color: #FFFFFF;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .hero-mask {
            background: linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.2) 100%),
                        linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%);
        }
        .btn-primary {
            @@apply px-8 py-4 bg-primary text-black font-semibold uppercase tracking-widest text-sm transition-all duration-300 hover:bg-primary-dark hover:shadow-[0_0_20px_rgba(212,175,55,0.3)] hover:-translate-y-1;
        }
        .btn-secondary {
            @@apply px-8 py-4 bg-transparent border border-primary text-primary font-semibold uppercase tracking-widest text-sm transition-all duration-300 hover:bg-primary hover:text-black;
        }
        .section-title {
            @@apply font-bold uppercase tracking-[0.2em] relative inline-block;
        }
        .section-title::after {
            content: '';
            @@apply absolute -bottom-4 left-0 w-12 h-1 bg-primary;
        }
        .gold-border-focus:focus {
            outline: none;
            border-color: #D4AF37;
            box-shadow: 0 0 0 1px #D4AF37;
        }
        .charcoal-bg {
            background-color: #111111;
        }
        .charcoal-border {
            border: 1px solid #222222;
        }
        .input-underline {
            background: transparent;
            border: none;
            border-bottom: 1px solid #333;
            border-radius: 0;
            padding-left: 0;
            padding-right: 0;
        }
        .input-underline:focus {
            box-shadow: none;
            border-bottom-color: #D4AF37;
        }
        .luxury-gradient-bg {
            background: radial-gradient(circle at top center, #1a1a1a 0%, #000000 100%);
        }
        .vehicle-glow {
            filter: drop-shadow(0 0 30px rgba(255,255,255,0.05));
        }
        .cinematic-img {
            filter: contrast(1.1) saturate(1.1) brightness(0.9);
        }
        .modal-overlay {
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(10px);
        }
        .tour-card {
            background: linear-gradient(145deg, #111 0%, #050505 100%);
        }
        .gold-bg {
            background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        }
        .mt-section-gap {
            margin-top: 8rem; /* 128px */
        }
        .noir-gradient {
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 40%, rgba(0,0,0,0) 100%);
        }
        .cinematic-card:hover .card-border {
            border-color: #D4AF37;
        }
        .cinematic-card:hover img {
            scale: 1.05;
        }
    </style>
</head>
<body class="font-body overflow-x-hidden selection:bg-primary/30 selection:text-on-primary-container">
    <!-- TopNavBar -->
    <header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 md:px-16 py-6 bg-black/90 backdrop-blur-xl border-b border-[#1A1A1A]">
        <a asp-action="Index" asp-controller="Home" class="text-2xl font-bold text-[#D4AF37] tracking-tighter">
            <img alt="LIA NCC Logo" class="h-16 w-auto object-contain" src="~/img/LiaNcc_logo.jpeg" />
        </a>
        <nav class="hidden md:flex gap-12 font-semibold tracking-widest uppercase text-[10px]">
            <a asp-action="Index" asp-controller="Home" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "text-[#D4AF37] border-b border-[#D4AF37] pb-1" : "text-gray-500 hover:text-[#D4AF37] transition-colors duration-300")">Home</a>
            <a asp-action="Fleet" asp-controller="Home" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Fleet" ? "text-[#D4AF37] border-b border-[#D4AF37] pb-1" : "text-gray-500 hover:text-[#D4AF37] transition-colors duration-300")">Flotta</a>
            <a href="/Home/Index#servizi" class="text-gray-500 hover:text-[#D4AF37] transition-colors duration-300">Servizi</a>
            <a asp-action="Tours" asp-controller="Home" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Tours" || ViewContext.RouteData.Values["Action"]?.ToString() == "TourDetail" ? "text-[#D4AF37] border-b border-[#D4AF37] pb-1" : "text-gray-500 hover:text-[#D4AF37] transition-colors duration-300")">Tour</a>
            <a href="#contatti" class="text-gray-500 hover:text-[#D4AF37] transition-colors duration-300">Contatti</a>

            @{
                var isItalian = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "it";
            }
            <div class="flex gap-2">
                <a href="?culture=it" class="@(isItalian ? "text-[#D4AF37]" : "text-gray-500 hover:text-[#D4AF37]")">IT</a>
                <span class="text-gray-500">|</span>
                <a href="?culture=en" class="@(!isItalian ? "text-[#D4AF37]" : "text-gray-500 hover:text-[#D4AF37]")">EN</a>
            </div>
        </nav>
        <a href="#booking-form" class="btn-secondary !text-[10px] !py-3">Prenota Ora</a>
    </header>

    @RenderBody()

    @inject LiaNcc.FE.Services.ILiaNccApiClient ApiClient
    @{
        var currentCulture = ViewContext.HttpContext.Request.Query["culture"].ToString();
        if (string.IsNullOrEmpty(currentCulture))
        {
            currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName;
        }
        var companyProfile = await ApiClient.GetCompanyProfileAsync(currentCulture);
    }

    <!-- Footer -->
    <footer class="w-full bg-[#000000] border-t border-[#1A1A1A] mt-32" id="contatti">
        <div class="w-full py-20 px-6 md:px-16 grid grid-cols-1 md:grid-cols-2 gap-12 max-w-7xl mx-auto items-center">
            <div>
                <div class="mb-8">
                    <a asp-action="Index" asp-controller="Home">
                        <img alt="LIA NCC Logo" class="h-16 w-auto object-contain" src="~/img/LiaNcc_logo.jpeg" />
                    </a>
                </div>
                <p class="font-bold text-[10px] tracking-[0.2em] uppercase text-gray-600 mb-8 text-[15px]">© @DateTime.Now.Year @(companyProfile?.Name ?? "LIA NCC"). L'ECCELLENZA IN MOVIMENTO.</p>
            </div>
            <div class="grid grid-cols-2 gap-8">
                <div class="flex flex-col gap-4">
                    <a href="#" class="font-bold text-[10px] tracking-[0.2em] uppercase text-gray-600 hover:text-[#D4AF37] transition-all">Privacy Policy</a>
                    <a href="#" class="font-bold text-[10px] tracking-[0.2em] uppercase text-gray-600 hover:text-[#D4AF37] transition-all">Termini e Condizioni</a>
                </div>
                <div class="flex flex-col gap-4 text-right">
                    @if(companyProfile?.CompanyContacts != null && companyProfile.CompanyContacts.Any())
                    {
                        foreach(var contact in companyProfile.CompanyContacts)
                        {
                            <p class="font-bold text-[10px] tracking-[0.2em] uppercase @(contact.Type == "Phone" || contact.Type == "WhatsApp" ? "text-[#D4AF37]" : "text-gray-600") text-[15px]">@contact.Value</p>
                        }
                    }
                    else
                    {
                        <p class="font-bold text-[10px] tracking-[0.2em] uppercase text-[#D4AF37] text-[15px]">+39 333 715 9308</p>
                        <p class="font-bold text-[10px] tracking-[0.2em] uppercase text-[#D4AF37] text-[15px]">+39 350 576 3433</p>
                        <p class="font-bold text-[10px] tracking-[0.2em] uppercase text-gray-600 text-[15px]">liamoto@alice.it</p>
                    }
                </div>
            </div>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
