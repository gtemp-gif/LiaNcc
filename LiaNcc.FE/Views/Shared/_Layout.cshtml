<body class="font-body overflow-x-hidden selection:bg-[#D4AF37]/30 selection:text-white relative flex flex-col min-h-screen">

    @{
        CompanyProfile? company = null;
        List<CompanyContactDto> contacts = new List<CompanyContactDto>();
        try
        {
            company = await CompanyApi.GetCompanyProfileAsync();
            contacts = await CompanyApi.GetContactsAsync();
        }
        catch { }

        var phone = contacts.FirstOrDefault(c => c.Type == "Phone")?.Value ?? "+39 333 715 9308";
        var phone2 = contacts.Skip(1).FirstOrDefault(c => c.Type == "Phone")?.Value ?? "+39 350 576 3433";
        var email = contacts.FirstOrDefault(c => c.Type == "Email")?.Value ?? "liamoto@alice.it";
        var address = company?.Address ?? "Via della Rimembranza, 108";
        var cityZip = $"{(company?.City ?? "Grassano")} - {(company?.ZipCode ?? "75014")}".Trim();
        var country = company?.Country ?? "Italia";
        var isItalian = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "it";
        
    }

    <header class="fixed top-0 w-full z-40 bg-black/90 backdrop-blur-xl border-b border-[#1A1A1A]">
        <div class="flex justify-between items-center px-6 md:px-16 py-4 md:py-6 relative z-50">
            <a asp-action="Index" asp-controller="Home" class="text-2xl font-bold text-[#D4AF37] tracking-tighter">
                <img alt="LIA NCC Logo" class="h-12 md:h-16 w-auto object-contain" src="~/img/LiaNcc_logo.jpeg" />
            </a>

            <nav class="hidden md:flex gap-12 font-semibold tracking-widest uppercase text-[10px] items-center">
                <a asp-action="Index" asp-controller="Home" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "text-[#D4AF37] border-b border-[#D4AF37] pb-1" : "text-gray-500 hover:text-[#D4AF37] transition-colors duration-300")">@Localizer["Home"]</a>
                <a asp-action="Fleet" asp-controller="Home" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Fleet" ? "text-[#D4AF37] border-b border-[#D4AF37] pb-1" : "text-gray-500 hover:text-[#D4AF37] transition-colors duration-300")">@Localizer["Fleet"]</a>
                <a href="/Home/Index#servizi" class="text-gray-500 hover:text-[#D4AF37] transition-colors duration-300">@Localizer["Services"]</a>
                <a asp-action="Tours" asp-controller="Home" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Tours" || ViewContext.RouteData.Values["Action"]?.ToString() == "TourDetail" ? "text-[#D4AF37] border-b border-[#D4AF37] pb-1" : "text-gray-500 hover:text-[#D4AF37] transition-colors duration-300")">@Localizer["Tours"]</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="contatti" class="text-gray-500 hover:text-[#D4AF37] transition-colors duration-300">@Localizer["Contacts"]</a>

                <div class="flex gap-2">
                    <a href="?culture=it&ui-culture=it" class="@(isItalian ? "text-[#D4AF37]" : "text-gray-500 hover:text-[#D4AF37]")">IT</a>
                    <span class="text-gray-500">|</span>
                    <a href="?culture=en&ui-culture=en" class="@(!isItalian ? "text-[#D4AF37]" : "text-gray-500 hover:text-[#D4AF37]")">EN</a>
                </div>

                <a href="/Home/Index#booking-form" class="btn-secondary !text-[10px] !py-3">@Localizer["BookNow"]</a>
            </nav>

            <button id="mobile-menu-btn" class="md:hidden text-[#D4AF37] focus:outline-none">
                <span class="material-symbols-outlined text-4xl" id="menu-icon">menu</span>
            </button>
        </div>

        <nav id="mobile-menu" class="fixed inset-0 h-screen w-screen bg-[#050505] flex-col hidden z-45 transition-all duration-300 pt-28 pb-8 overflow-y-auto">
            <div class="flex flex-col items-center justify-center gap-8 font-semibold tracking-[0.2em] uppercase flex-grow">
                <a asp-action="Index" asp-controller="Home" class="mobile-link text-white hover:text-[#D4AF37] text-lg">@Localizer["Home"]</a>
                <a asp-action="Fleet" asp-controller="Home" class="mobile-link text-white hover:text-[#D4AF37] text-lg">@Localizer["Fleet"]</a>
                <a href="/Home/Index#servizi" class="mobile-link text-white hover:text-[#D4AF37] text-lg">@Localizer["Services"]</a>
                <a asp-action="Tours" asp-controller="Home" class="mobile-link text-white hover:text-[#D4AF37] text-lg">@Localizer["Tours"]</a>
                <a href="/Home/Index#contatti" class="mobile-link text-white hover:text-[#D4AF37] text-lg">@Localizer["Contacts"]</a>

                <div class="flex gap-6 mt-4 border-t border-[#1A1A1A] pt-8 w-[60%] justify-center">
                    <a href="?culture=it&ui-culture=it" class="@(isItalian ? "text-[#D4AF37]" : "text-gray-500") text-xl">IT</a>
                    <span class="text-gray-500 text-xl">|</span>
                    <a href="?culture=en&ui-culture=en" class="@(!isItalian ? "text-[#D4AF37]" : "text-gray-500") text-xl">EN</a>
                </div>

                <a href="/Home/Index#booking-form" class="mobile-link bg-[#D4AF37] text-black px-10 py-5 mt-6 text-xs font-bold tracking-[0.3em]">@Localizer["BookNow"]</a>
            </div>

            <div class="mt-12 border-t border-[#1A1A1A] pt-8 w-full px-8 pb-4">
                <div class="grid grid-cols-2 gap-4 w-full">
                    <div class="flex flex-col gap-4 items-start text-left">
                        <span class="text-[#D4AF37] font-bold text-[9px] tracking-widest uppercase mb-1">@Localizer["Contacts"]</span>
                        @foreach (var contact in contacts.Where(c => c.Type == "Phone" || c.Type == "WhatsApp"))
                        {
                            <a href="tel:@contact.Value.Replace(" ", "")" class="font-bold text-[10px] tracking-[0.1em] uppercase text-white hover:text-[#D4AF37] transition-all">@contact.Value</a>
                        }
                        @foreach (var contact in contacts.Where(c => c.Type == "Email"))
                        {
                            <a href="mailto:@contact.Value" class="font-bold text-[10px] tracking-[0.1em] uppercase text-gray-400 hover:text-[#D4AF37] transition-all break-all sm:break-normal">@contact.Value</a>
                        }
                    </div>

                    <div class="flex flex-col gap-4 items-end text-right">
                        <span class="text-[#D4AF37] font-bold text-[9px] tracking-widest uppercase mb-1">@Localizer["Legal"]</span>
                        <a asp-controller="Home" asp-action="Legal" asp-fragment="privacy" class="mobile-link font-bold text-[10px] tracking-[0.2em] uppercase text-gray-400 hover:text-[#D4AF37] transition-all">@Localizer["PrivacyPolicy"]</a>
                        <a asp-controller="Home" asp-action="Legal" asp-fragment="termini" class="mobile-link font-bold text-[10px] tracking-[0.2em] uppercase text-gray-400 hover:text-[#D4AF37] transition-all">@Localizer["TermsConditions"]</a>
                    </div>
                </div>
                <div class="w-full text-center border-t border-[#1A1A1A] pt-6 mt-8">
                    <p class="font-bold text-[9px] tracking-[0.2em] uppercase text-gray-600 leading-loose">
                        © @DateTime.Now.Year @(company?.Name ?? "LIA NCC").<br /> @Localizer["ExcellenceInMotion"]
                    </p>

                    @if (!string.IsNullOrWhiteSpace(company?.VatNumber))
                    {
                        <p class="font-bold text-[9px] tracking-[0.15em] uppercase text-gray-600 mt-4">
                            P. IVA @company.VatNumber
                        </p>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow">
        @RenderBody()
    </main>
    <footer class="w-full bg-[#000000] border-t border-[#1A1A1A] mt-auto" id="contatti">
        <div class="w-full px-6 md:px-16 py-20 max-w-7xl mx-auto">

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

                <!-- Brand -->
                <div class="lg:col-span-6 flex flex-col items-center lg:items-start text-center lg:text-left">
                    <a asp-action="Index" asp-controller="Home" class="mb-10">
                        <img alt="LIA NCC Logo"
                             class="h-20 w-auto object-contain"
                             src="~/img/LiaNcc_logo.jpeg" />
                    </a>

                    <p class="font-bold text-[13px] tracking-[0.2em] uppercase text-gray-400 leading-loose">
                        @Localizer["ExcellenceInMotion"]
                    </p>
                </div>

                <!-- Sede -->
                <div class="lg:col-span-3 flex flex-col items-center lg:items-start text-center lg:text-left">
                    <h3 class="text-white font-bold text-[15px] tracking-[0.25em] uppercase mb-10">
                        @Localizer["Location"]
                    </h3>

                    <div class="flex flex-col gap-4">
                        <span class="font-bold text-[12px] tracking-[0.14em] uppercase text-gray-500">
                            @address
                        </span>

                        <span class="font-bold text-[12px] tracking-[0.14em] uppercase text-gray-500">
                            @cityZip
                        </span>

                        <span class="font-bold text-[12px] tracking-[0.14em] uppercase text-gray-500">
                            @country
                        </span>
                    </div>
                </div>

                <!-- Contatti -->
                <div class="lg:col-span-3 flex flex-col items-center lg:items-start text-center lg:text-left">
                    <h3 class="text-white font-bold text-[15px] tracking-[0.25em] uppercase mb-10">
                        @Localizer["Contacts"]
                    </h3>

                    <div class="flex flex-col gap-4">

                        @foreach (var contact in contacts.Where(c => c.Type == "Phone" || c.Type == "WhatsApp"))
                        {
                            <a href="tel:@contact.Value.Replace(" ", "")"
                               class="font-bold text-[12px] tracking-[0.14em] uppercase text-gray-500 hover:text-[#D4AF37] transition-all">
                                @contact.Value
                            </a>
                        }

                        @foreach (var contact in contacts.Where(c => c.Type == "Email"))
                        {
                            <a href="mailto:@contact.Value"
                               class="font-bold text-[12px] tracking-[0.14em] uppercase text-gray-500 hover:text-[#D4AF37] transition-all break-all">
                                @contact.Value
                            </a>
                        }

                    </div>
                </div>

            </div>

            <!-- Bottom Bar -->
            <div class="border-t border-[#252525] mt-20 pt-8">
                <div class="flex flex-col md:flex-row justify-between items-center gap-6">

                    <p class="font-bold text-[10px] tracking-[0.25em] uppercase text-gray-600 text-center md:text-left">
                        © @DateTime.Now.Year @(company?.Name ?? "LIA NCC")
                    </p>

                    <div class="flex flex-col md:flex-row items-center gap-4 md:gap-10">

                        @if (!string.IsNullOrWhiteSpace(company?.VatNumber))
                        {
                            <p class="font-bold text-[10px] tracking-[0.25em] uppercase text-gray-600">
                                P. IVA @company.VatNumber
                            </p>
                        }

                        <a asp-controller="Home"
                           asp-action="Legal"
                           asp-fragment="privacy"
                           class="font-bold text-[10px] tracking-[0.25em] uppercase text-gray-600 hover:text-[#D4AF37] transition-all">
                            @Localizer["PrivacyPolicy"]
                        </a>

                        <a asp-controller="Home"
                           asp-action="Legal"
                           asp-fragment="termini"
                           class="font-bold text-[10px] tracking-[0.25em] uppercase text-gray-600 hover:text-[#D4AF37] transition-all">
                            @Localizer["TermsConditions"]
                        </a>

                    </div>

                </div>
            </div>

        </div>
    </footer>
    

    <div id="scroll-controls" class="fixed bottom-8 right-6 md:right-10 z-[90] flex flex-col gap-3 opacity-0 translate-y-4 transition-all duration-500 pointer-events-none">

        <button onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
                class="w-12 h-12 flex items-center justify-center rounded-full bg-black/60 backdrop-blur-md border border-[#D4AF37]/50 text-[#D4AF37] hover:bg-[#D4AF37] hover:text-black transition-all group shadow-[0_0_15px_rgba(212,175,55,0.2)]"
                title="@Localizer["BackToTop"]">
            <span class="material-symbols-outlined font-light transition-transform duration-300 group-hover:-translate-y-1">expand_less</span>
        </button>

        <button onclick="window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' })"
                class="w-12 h-12 flex items-center justify-center rounded-full bg-black/60 backdrop-blur-md border border-[#D4AF37]/50 text-[#D4AF37] hover:bg-[#D4AF37] hover:text-black transition-all group shadow-[0_0_15px_rgba(212,175,55,0.2)]"
                title="@Localizer["GoToContacts"]">
            <span class="material-symbols-outlined font-light transition-transform duration-300 group-hover:translate-y-1">expand_more</span>
        </button>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/it.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
        // Logica Menu Mobile
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        function toggleMenu() {
        mobileMenu.classList.toggle('hidden');
        mobileMenu.classList.toggle('flex');
        document.body.classList.toggle('overflow-hidden');
        menuIcon.textContent = mobileMenu.classList.contains('hidden') ? 'menu' : 'close';
        }

        if (menuBtn) {
        menuBtn.addEventListener('click', toggleMenu);
        }

        mobileLinks.forEach(link => {
        link.addEventListener('click', toggleMenu);
        });

        // Logica Controlli di Scroll
        const scrollControls = document.getElementById('scroll-controls');
        if (scrollControls) {
        window.addEventListener('scroll', function() {
        if (window.scrollY > 400) {
        scrollControls.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        scrollControls.classList.add('opacity-100', 'translate-y-0');
        } else {
        scrollControls.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        scrollControls.classList.remove('opacity-100', 'translate-y-0');
        }
        });
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>