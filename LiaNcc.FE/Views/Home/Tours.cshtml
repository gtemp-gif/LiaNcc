@model ToursViewModel
@{
    ViewData["Title"] = "I Nostri Tour";
    Layout = "_Layout";
}

<section class="pt-40 pb-20 px-6 md:px-16 bg-black">
    <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-semibold text-white mb-8 section-title">Tour Esclusivi</h1>
        <p class="text-xl text-gray-400 max-w-3xl mx-auto font-light">Scoprite le bellezze dell'Italia con i nostri tour personalizzati, tra cultura, storia ed enogastronomia.</p>
    </div>
</section>

<section class="py-20 px-6 md:px-16 bg-[#050505]">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            @foreach (var tour in Model.Tours)
            {
                <a asp-action="TourDetail" asp-controller="Home" asp-route-slug="@tour.Slug" class="relative h-[600px] group overflow-hidden block charcoal-border">
                    <img alt="@tour.Name" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" src="@MediaUrlBuilder.Build(tour.CoverImageUrl)" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
                    <div class="absolute bottom-16 left-12 right-12">
                        <span class="text-[#D4AF37] font-bold text-[12px] tracking-[0.4em] uppercase mb-4 block">@tour.CategoryName</span>
                        <h3 class="text-4xl md:text-5xl font-semibold text-white mb-6 leading-tight">@tour.Name</h3>
                        <p class="text-gray-300 font-light text-lg mb-8 line-clamp-2 max-w-xl">@tour.Description</p>
                        <div class="flex items-center gap-6">
                            <span class="text-white font-bold text-2xl">@(tour.Price?.ToString("C", new System.Globalization.CultureInfo("it-IT")) ?? "N/D")</span>
                            <div class="flex items-center gap-2 text-[#D4AF37]">
                                <span class="text-xs uppercase tracking-[0.2em] font-bold">Scopri di più</span>
                                <span class="material-symbols-outlined">arrow_forward</span>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>
