@using LiaNcc.FE.Services
@model LiaNcc.FE.Models.ViewModels.ToursPageViewModel
@inject IMediaUrlBuilder MediaUrlBuilder
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@{
    ViewData["Title"] = "Tutti i Tour d'Autore";
    var heroSection = Model.CmsPage?.PageSections?.FirstOrDefault(s => s.Name == "Hero");
}

<main class="pt-48 pb-32">
<section class="max-w-7xl mx-auto px-8">
<!-- Section Header -->
<div class="mb-24 flex flex-col items-center text-center">
<span class="font-bold text-primary tracking-[0.4em] uppercase text-xs mb-4 block">@(heroSection?.Title ?? "Esperienza Chauffeur Premium")</span>
<h1 class="text-4xl md:text-5xl font-medium text-white mb-6 tracking-tight uppercase" style="letter-spacing: 3px;">@(heroSection?.Description ?? "Tutti i Tour d'Autore")</h1>
<div class="w-24 h-px bg-[#D4AF37]"></div>
</div>
<!-- Bento / Poster Grid -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
@if(Model.Tours != null && Model.Tours.Any())
{
    var index = 0;
    foreach(var tour in Model.Tours)
    {
        var colSpanClass = index % 3 == 0 ? "md:col-span-8 aspect-[16/10]" : "md:col-span-4 aspect-[3/4]";
        <div class="@colSpanClass group relative overflow-hidden cinematic-card cursor-pointer charcoal-border" onclick="window.location.href='@Url.Action("TourDetail", "Home", new { slug = tour.Slug })'">
            <div class="card-border absolute inset-0 border border-zinc-900 z-20 transition-colors duration-500 pointer-events-none"></div>
            @if(!string.IsNullOrEmpty(tour.CoverImageUrl))
            {
                <img alt="@tour.Name" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700" src="@MediaUrlBuilder.Build(tour.CoverImageUrl)"/>
            }
            <div class="absolute inset-0 noir-gradient z-10"></div>
            <div class="absolute bottom-0 left-0 p-10 z-30">
                <h2 class="text-3xl md:text-4xl font-semibold text-white mb-2 uppercase tracking-widest">@tour.Name</h2>
                @if(index % 3 == 0)
                {
                    <p class="text-sm text-on-surface-variant mb-6 max-w-md font-light">@tour.Description</p>
                }
                <a class="inline-flex items-center space-x-3 text-[#D4AF37] font-bold text-[10px] uppercase tracking-[0.2em] hover:translate-x-2 transition-transform duration-300" asp-action="TourDetail" asp-controller="Home" asp-route-slug="@tour.Slug">
                    <span>Scopri di più</span>
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
        </div>
        index++;
    }
}
</div>
<!-- Call to Action -->
<div class="mt-section-gap border border-[#1A1A1A] p-16 bg-black">
<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center w-full max-w-7xl mx-auto">
<div class="max-w-xl text-left">
<h3 class="text-3xl font-semibold text-white mb-6 uppercase tracking-widest leading-tight">Un itinerario su misura per le vostre esigenze.</h3>
<p class="text-lg text-on-surface-variant font-light">Collaboriamo con voi per creare esperienze di viaggio esclusive, garantendo la massima discrezione e precisione in ogni dettaglio.</p>
</div>
<div class="w-full">
<form action="javascript:void(0);" class="flex flex-col gap-4 font-body" id="tour-contact" onsubmit="alert('Grazie per la tua richiesta. Ti ricontatteremo al più presto.')">
<div class="relative">
<input class="w-full bg-black border border-[#D4AF37] px-4 py-3 text-white text-sm focus:outline-none focus:ring-1 focus:ring-[#D4AF37] placeholder-gray-500 uppercase tracking-widest font-medium transition-all" placeholder="Nome" required="" type="text"/>
</div>
<div class="relative">
<input class="w-full bg-black border border-[#D4AF37] px-4 py-3 text-white text-sm focus:outline-none focus:ring-1 focus:ring-[#D4AF37] placeholder-gray-500 uppercase tracking-widest font-medium transition-all" placeholder="Email" required="" type="email"/>
</div>
<div class="relative">
<textarea class="w-full bg-black border border-[#D4AF37] px-4 py-3 text-white text-sm focus:outline-none focus:ring-1 focus:ring-[#D4AF37] placeholder-gray-500 uppercase tracking-widest font-medium transition-all" placeholder="Descrivi il tour che desideri..." required="" rows="3"></textarea>
</div>
<button class="w-full bg-[#D4AF37] text-black font-bold uppercase text-[10px] tracking-widest py-4 hover:scale-105 transition-transform" type="submit">Richiedi Contatto</button>
</form>
</div>
</div>
</div>
</section>
</main>
