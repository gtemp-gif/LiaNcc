<!-- Reservation Form -->
<section class="py-32 px-6 md:px-16" id="booking-form">
    <div class="max-w-4xl mx-auto">
        <div class="mb-12 text-left">
            <h2 class="text-4xl md:text-5xl font-semibold text-white mb-4 section-title text-[24px] font-medium">@(contactSection?.Title ?? "Richiesta Prenotazione VIP")</h2>
            <p class="text-gray-400 font-light text-lg text-[15px]">@(contactSection?.Description ?? "Compila il modulo per ricevere un preventivo personalizzato immediato.")</p>
        </div>
        <div class="charcoal-border bg-[#050505] p-8 md:p-20 relative">
            <form asp-action="Create" asp-controller="Bookings" method="post" id="form-booking" class="space-y-8">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
                        <input name="FullName" required class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" placeholder="Mario Rossi" type="text" />
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
                        <input name="Email" required class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" placeholder="mario@esempio.it" type="email" />
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data del Servizio</label>
                        <input name="ServiceDate" required class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all [color-scheme:dark]" type="date" />
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Tipo di Servizio</label>
                        <select name="ServiceType" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" id="service-select">
                            <option class="bg-black">Transfer Aeroportuale</option>
                            <option class="bg-black">Tour Personalizzato</option>
                            <option class="bg-black">Evento Speciale</option>
                            <option class="bg-black">Altro</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Messaggio / Richieste Speciali</label>
                    <textarea name="Message" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" placeholder="Indica dettagli aggiuntivi..." rows="3"></textarea>
                </div>
                <button class="w-full py-6 gold-bg text-black font-bold uppercase text-[12px] tracking-[0.2em] hover:bg-[#E5C158] transition-all mt-8" type="submit">Invia Richiesta di Prenotazione</button>
                <div id="booking-message" class="hidden mt-4 p-4 text-center font-bold"></div>
            </form>
        </div>
    </div>
</section>

<!-- Map & Location -->
<section class="py-32 px-6 md:px-16 max-w-7xl mx-auto border-t border-[#1A1A1A]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <div class="h-full min-h-[400px] border border-[#1A1A1A] relative overflow-hidden">
            <iframe allowfullscreen="" height="100%" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3032.553259837731!2d16.2798153!3d40.6358178!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1338dfd6e64c3c39%3A0x6b77c4f4a3e9c8e!2sVia%20delle%20Rimembranze%2C%2075014%20Grassano%20MT!5e0!3m2!1sit!2sit!4v1710000000000!5m2!1sit!2sit" style="border:0; filter: grayscale(100%) invert(92%) contrast(83%);" width="100%"></iframe>
        </div>
        <div class="flex flex-col justify-center text-left">
            <h2 class="text-4xl md:text-5xl font-semibold text-white mb-8 section-title text-[24px] font-medium">La Nostra Sede</h2>
            <p class="text-lg text-gray-400 font-light mb-8 leading-relaxed text-[15px]">@Model.Company?.Address, @Model.Company?.City @Model.Company?.ZipCode</p>
            <div class="pt-8 border-t border-[#1A1A1A] space-y-4">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-[#D4AF37]">location_on</span>
                    <span class="text-gray-300 font-bold tracking-wide">@Model.Company?.Address, @Model.Company?.City @Model.Company?.ZipCode</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contatti Rapidi -->
<section class="py-32 bg-[#050505]" id="contatti">
    <div class="px-6 md:px-16 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
            <div class="text-left">
                <h2 class="text-5xl font-semibold mb-12 text-white section-title text-[24px] font-medium">Contattaci</h2>
                <div class="space-y-12">
                    <div class="flex items-start gap-6">
                        <span class="material-symbols-outlined text-[#D4AF37] text-4xl">phone_iphone</span>
                        <div>
                            <p class="font-bold text-gray-500 uppercase tracking-widest mb-2 text-[10px] text-[15px]">Cellulare</p>
                            @foreach(var contact in (await CompanyApi.GetContactsAsync()).Where(c => c.Type == "Phone" || c.Type == "WhatsApp"))
                            {
                                <p class="text-2xl font-bold text-white text-[15px]">@contact.Value</p>
                            }
                        </div>
                    </div>
                    <div class="flex items-start gap-6">
                        <span class="material-symbols-outlined text-[#D4AF37] text-4xl">mail</span>
                        <div>
                            <p class="font-bold text-gray-500 uppercase tracking-widest mb-2 text-[10px] text-[15px]">Email</p>
                            @foreach(var contact in (await CompanyApi.GetContactsAsync()).Where(c => c.Type == "Email"))
                            {
                                <p class="text-2xl font-bold text-white text-[15px]">@contact.Value</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="charcoal-border p-12 bg-black">
                <form asp-action="SendMessage" asp-controller="Contact" method="post" id="form-contact" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input name="FullName" required class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 font-light" placeholder="Il Tuo Nome" type="text" />
                    <input name="Email" required class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 font-light" placeholder="Indirizzo Email" type="email" />
                    <textarea name="Message" required class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 font-light" placeholder="Scrivi qui la tua richiesta..." rows="4"></textarea>
                    <button class="w-full btn-secondary !text-[11px] !py-5" type="submit">Invia Messaggio</button>
                    <div id="contact-message" class="hidden mt-4 p-4 text-center font-bold"></div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.service-book-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const service = this.getAttribute('data-service');
                const select = document.getElementById('service-select');
                if (select && service) {
                    for (let i = 0; i < select.options.length; i++) {
                        if (select.options[i].text === service) {
                            select.selectedIndex = i;
                            break;
                        }
                    }
                }
            });
        });

        async function handleFormSubmit(event, messageId) {
            event.preventDefault();
            const form = event.target;
            const messageDiv = document.getElementById(messageId);
            const formData = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                messageDiv.textContent = result.message;
                messageDiv.classList.remove('hidden', 'text-red-500', 'text-green-500');
                messageDiv.classList.add(result.success ? 'text-green-500' : 'text-red-500');

                if (result.success) form.reset();
            } catch (error) {
                messageDiv.textContent = "Si è verificato un errore.";
                messageDiv.classList.remove('hidden', 'text-green-500');
                messageDiv.classList.add('text-red-500');
            }
        }

        document.getElementById('form-booking')?.addEventListener('submit', (e) => handleFormSubmit(e, 'booking-message'));
        document.getElementById('form-contact')?.addEventListener('submit', (e) => handleFormSubmit(e, 'contact-message'));
    </script>
}
