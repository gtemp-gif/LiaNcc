@using LiaNcc.FE.Services
@model LiaNcc.FE.Models.ViewModels.HomePageViewModel
@inject IMediaUrlBuilder MediaUrlBuilder
@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";

    var heroSection = Model.CmsPage?.PageSections?.FirstOrDefault(s => s.Name == "Hero");
    var aboutSection = Model.CmsPage?.PageSections?.FirstOrDefault(s => s.Name == "Chi Siamo");
}

<!-- Hero Section -->
<section class="relative h-screen flex items-center justify-center text-center px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img alt="Hero background" class="w-full h-full object-cover cinematic-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuABLx3pL6IWe1fmg1Mytk9zyigB_MJ_fExwdSaSwqMknbOfTcmaf0rpIm6WXV22AKYSA_iMCq5mE70DVqPkx4m6W1pjJtCnWbUwFFx35kKDyE4L5I4-k8I2TL6qpmBO9dDbaAz7DzAUeg0qeggH_Oi78bo9_NgfTSADO71wr0LX-5RPPhcLImPcJAs52atpzLpoDUeWEwBkaZ9DwWrDSqYdeoQOXfoKMODMHiq7ngFLLfQ_orO75Nzfe64ssA2_sjT_XD-YtW6g13q3" />
        <div class="absolute inset-0 hero-mask"></div>
    </div>
    <div class="relative z-10 max-w-5xl">
        <span class="font-bold text-primary tracking-[0.4em] uppercase text-xs mb-6 block">@(heroSection?.Title ?? "Esperienza Chauffeur Premium")</span>
        <h1 class="text-4xl md:text-5xl font-medium text-white mb-8 tracking-tight uppercase" style="letter-spacing: 3px;">@(heroSection?.Description ?? "Il Vertice del Trasporto Privato")</h1>
        <p class="text-lg md:text-xl text-on-surface-variant max-w-2xl mx-auto mb-12 font-light text-[15px]">Sperimenta discrezione, puntualità e comfort impareggiabili nelle destinazioni più prestigiose d'Italia.</p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
            @if(heroSection?.CallToActions != null && heroSection.CallToActions.Any())
            {
                foreach(var cta in heroSection.CallToActions)
                {
                    <a href="@cta.Url" class="bg-[#D4AF37] text-black px-10 py-5 font-bold uppercase text-xs tracking-widest hover:scale-105 transition-transform inline-block">@cta.Label</a>
                }
            }
            else
            {
                <button class="bg-[#D4AF37] text-black px-10 py-5 font-bold uppercase text-xs tracking-widest hover:scale-105 transition-transform">Prenota il tuo Viaggio</button>
                <a class="btn-secondary !text-xs !py-5 !px-10" asp-action="Fleet" asp-controller="Home">Scopri la Flotta</a>
            }
        </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
        <span class="material-symbols-outlined text-[#D4AF37] text-3xl">expand_more</span>
    </div>
</section>
<!-- Chi Siamo -->
<section class="py-32 px-6 md:px-16 bg-black">
    <div class="max-w-7xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-semibold text-white mb-12 section-title text-[24px] font-medium">@(aboutSection?.Title ?? "Chi Siamo")</h2>
        <div class="max-w-[800px] mx-auto mb-16">
            <p class="text-lg md:text-xl text-on-surface leading-relaxed font-light text-[15px]">
                @Html.Raw(aboutSection?.Description ?? "LIA NCC è un’azienda specializzata nel servizio di noleggio con conducente (NCC) e nell’organizzazione di transfer e tour personalizzati, operativa principalmente tra Basilicata e Puglia. Operativi dal 2009, mettiamo a disposizione dei nostri clienti anni di experience nel settore del trasporto persone, garantendo sempre servizi affidabili, puntuali e confortevoli.")
            </p>
        </div>
        <div class="border-t border-[#D4AF37]/20 pt-10">
            <div class="flex flex-wrap items-center justify-center gap-0 text-center uppercase tracking-widest text-[10px] text-on-surface-variant font-semibold">
                <div class="px-8 py-4 border-r border-[#D4AF37] w-full md:w-auto">Puntualità e affidabilità</div>
                <div class="px-8 py-4 border-r border-[#D4AF37] w-full md:w-auto">Comfort e sicurezza</div>
                <div class="px-8 py-4 border-r border-[#D4AF37] w-full md:w-auto">Massima disponibilità</div>
                <div class="px-8 py-4 border-r border-[#D4AF37] w-full md:w-auto">Servizi personalizzati</div>
                <div class="px-8 py-4 w-full md:w-auto">Conoscenza del territorio</div>
            </div>
        </div>
    </div>
</section>
<!-- I Nostri Servizi -->
<section class="py-32 bg-[#050505]" id="servizi">
    <div class="px-6 md:px-16 max-w-7xl mx-auto">
        <div class="mb-20 text-left">
            <h2 class="text-4xl md:text-5xl font-semibold text-white mb-4 section-title text-[24px] font-medium">Servizi Esclusivi</h2>
            <div class="w-24 h-1 bg-[#D4AF37]"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @if(Model.FeaturedServices != null && Model.FeaturedServices.Any())
            {
                foreach(var service in Model.FeaturedServices)
                {
                    <div class="charcoal-border p-8 hover:border-[#D4AF37] transition-all duration-500 bg-black group cursor-pointer">
                        @if(!string.IsNullOrEmpty(service.CoverImageUrl))
                        {
                            <img alt="@service.Name" class="w-full h-48 object-cover mb-6 grayscale group-hover:grayscale-0 transition-all duration-700" src="@MediaUrlBuilder.Build(service.CoverImageUrl)" />
                        }
                        <h3 class="text-2xl font-semibold mb-2 text-[24px] font-medium">
                            @if (!string.IsNullOrEmpty(service.Icon))
                            {
                                <span class="material-symbols-outlined align-middle mr-2 text-[#D4AF37]">@service.Icon</span>
                            }
                            @service.Name
                        </h3>
                        <p class="text-gray-500 mb-6 font-light text-[15px]">@service.Description</p>
                        @if(service.IsBookable)
                        {
                            <div class="text-[#D4AF37] font-bold text-xl flex justify-between items-center w-full mt-4">
                                <a class="service-book-btn btn-secondary !px-6 !py-2 !text-[10px] ml-auto" data-service="@service.Name" href="#booking-form">PRENOTA ORA</a>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</section>
<!-- Destinazioni -->
<section class="py-32 px-6 md:px-16 overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start mb-16 gap-6">
            <div class="text-left">
                <h2 class="text-4xl md:text-5xl font-semibold text-white tracking-tight section-title text-[24px] font-medium">Destinazioni d'Autore</h2>
            </div>
            <a class="group font-display uppercase text-[#D4AF37] text-[12px] tracking-[0.2em] transition-all duration-300 hover:underline hover:underline-offset-4" asp-action="Tours" asp-controller="Home">MOSTRA TUTTI I TOUR <span class="inline-block transition-transform duration-300 group-hover:translate-x-2">➔</span></a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @if(Model.FeaturedTours != null && Model.FeaturedTours.Any())
            {
                foreach(var tour in Model.FeaturedTours)
                {
                    <a class="relative h-[500px] group overflow-hidden block" asp-action="TourDetail" asp-controller="Home" asp-route-slug="@tour.Slug">
                        @if(!string.IsNullOrEmpty(tour.CoverImageUrl))
                        {
                            <img alt="@tour.Name" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" src="@MediaUrlBuilder.Build(tour.CoverImageUrl)" />
                        }
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
                        <div class="absolute bottom-10 left-10 right-10">
                            <h3 class="text-3xl font-semibold mt-2 leading-tight text-[24px] font-medium">@tour.Name</h3>
                            <div class="mt-4 overflow-hidden h-0 group-hover:h-8 transition-all duration-500 opacity-0 group-hover:opacity-100 flex items-center gap-2 text-[#D4AF37]">
                                <span class="text-xs uppercase tracking-widest font-bold">Vedi Dettagli</span>
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </div>
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</section>
<!-- Fleet -->
<section class="py-32 bg-[#0a0a0a]" id="fleet">
    <div class="px-6 md:px-16 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start mb-16 gap-6">
            <div class="text-left">
                <h2 class="text-4xl md:text-5xl font-semibold text-white tracking-tight section-title text-[24px] font-medium">FLOTTA D'ECCELLENZA</h2>
            </div>
            <a class="group font-display uppercase text-[#D4AF37] text-[12px] tracking-[0.2em] transition-all duration-300 hover:underline hover:underline-offset-4" asp-action="Fleet" asp-controller="Home">MOSTRA TUTTA LA FLOTTA <span class="inline-block transition-transform duration-300 group-hover:translate-x-2">➔</span></a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @if(Model.FeaturedVehicles != null && Model.FeaturedVehicles.Any())
            {
                foreach(var vehicle in Model.FeaturedVehicles)
                {
                    <div class="charcoal-border bg-black overflow-hidden group">
                        <div class="relative h-64 overflow-hidden">
                            @if(vehicle.VehicleFeatures != null && vehicle.VehicleFeatures.Any())
                            {
                                // Show a placeholder or first image if available
                                <img alt="@vehicle.Name" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="@MediaUrlBuilder.Build(null)" />
                            }
                            @if(vehicle.IsBookable)
                            {
                                <div class="absolute top-4 right-4 bg-black/80 px-4 py-2 border border-[#D4AF37]">
                                    <span class="text-[#D4AF37] font-bold text-[9px] tracking-widest uppercase">DISPONIBILE ORA</span>
                                </div>
                            }
                        </div>
                        <div class="p-8">
                            <h3 class="text-2xl font-semibold mb-2 text-[24px] font-medium">@vehicle.Name</h3>
                            <p class="text-gray-500 font-light mb-6 text-[15px]">@vehicle.Description</p>
                            <div class="flex gap-4 border-t border-[#1A1A1A] pt-6">
                                <span class="flex items-center gap-2 text-[11px] text-gray-400 font-bold tracking-wider uppercase"><span class="material-symbols-outlined text-sm">person</span> @vehicle.Seats Posti</span>
                                <span class="flex items-center gap-2 text-[11px] text-gray-400 font-bold tracking-wider uppercase"><span class="material-symbols-outlined text-sm">luggage</span> @vehicle.Luggages Valigie</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>
<!-- Partners -->
@if(Model.Partners != null && Model.Partners.Any())
{
    <section class="py-20 bg-black border-y border-[#1A1A1A]">
        <div class="px-6 md:px-16 max-w-7xl mx-auto flex flex-wrap justify-center items-center gap-20 opacity-40 grayscale hover:opacity-100 transition-opacity duration-700">
            @foreach(var partner in Model.Partners)
            {
                if(!string.IsNullOrEmpty(partner.LogoUrl))
                {
                    <a href="@(string.IsNullOrEmpty(partner.WebsiteUrl) ? "#" : partner.WebsiteUrl)" target="_blank">
                        <img src="@MediaUrlBuilder.Build(partner.LogoUrl)" alt="@partner.Name" class="h-12 object-contain" />
                    </a>
                }
                else
                {
                    <span class="font-bold text-2xl text-[#D4AF37] tracking-widest uppercase">@partner.Name</span>
                }
            }
        </div>
    </section>
}
<!-- Reservation Form -->
<section class="py-32 px-6 md:px-16" id="booking-form">
    <div class="max-w-4xl mx-auto">
        <div class="mb-12 text-left">
            <h2 class="text-4xl md:text-5xl font-semibold text-white mb-4 section-title text-[24px] font-medium">Richiesta Prenotazione VIP</h2>
            <p class="text-gray-400 font-light text-lg text-[15px]">Compila il modulo per ricevere un preventivo personalizzato immediato.</p>
        </div>
        <div class="charcoal-border bg-[#050505] p-8 md:p-20 relative">
            <form class="space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
                        <input class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" placeholder="Mario Rossi" type="text" />
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
                        <input class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" placeholder="mario@esempio.it" type="email" />
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data del Servizio</label>
                        <input class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all [color-scheme:dark]" type="date" />
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Tipo di Servizio</label>
                        <select class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" id="service-select">
                            <option class="bg-black">Transfer Aeroportuale</option>
                            <option class="bg-black">Tour Personalizzato</option>
                            <option class="bg-black">Evento Speciale</option>
                            <option class="bg-black">Altro</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Messaggio / Richieste Speciali</label>
                    <textarea class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all" placeholder="Indica dettagli aggiuntivi..." rows="3"></textarea>
                </div>
                <button class="w-full py-6 gold-bg text-black font-bold uppercase text-[12px] tracking-[0.2em] hover:bg-[#E5C158] transition-all mt-8" type="submit">Invia Richiesta di Prenotazione</button>
            </form>
        </div>
    </div>
</section>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const bookBtns = document.querySelectorAll('.service-book-btn');
        const serviceSelect = document.getElementById('service-select');

        bookBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const serviceName = e.target.getAttribute('data-service');
                if (serviceName) {
                    // Try to match the select option, or default to "Altro"
                    let optionExists = Array.from(serviceSelect.options).some(opt => opt.text === serviceName);

                    if (optionExists) {
                        serviceSelect.value = serviceName;
                    } else {
                        serviceSelect.value = "Altro";
                    }
                }
            });
        });
    });
</script>
