@model TourDetailViewModel
@{
    ViewData["Title"] = Model.Tour?.Name ?? "Dettaglio Tour";
    Layout = "_Layout";
    var tour = Model.Tour;
}

@if (tour != null)
{
    <!-- Hero Detail -->
    <section class="relative h-[70vh] flex items-center justify-center text-center px-6 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img alt="@tour.Name" class="w-full h-full object-cover cinematic-img" src="@MediaUrlBuilder.Build(tour.CoverImageUrl)" />
            <div class="absolute inset-0 hero-mask"></div>
        </div>
        <div class="relative z-10 max-w-5xl">
            <span class="font-bold text-primary tracking-[0.4em] uppercase text-xs mb-6 block">@tour.TourCategory?.Name</span>
            <h1 class="text-5xl md:text-7xl font-medium text-white mb-8 tracking-tight uppercase" style="letter-spacing: 5px;">@tour.HeroTitle</h1>
            <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl mx-auto font-light">@tour.HeroSubtitle</p>
        </div>
    </section>

    <!-- Experience Section -->
    <section class="py-32 px-6 md:px-16 bg-black">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl md:text-5xl font-semibold text-white mb-12 section-title">L'Esperienza</h2>
                <div class="prose prose-invert prose-lg max-w-none text-gray-400 font-light leading-loose">
                    @tour.ExperienceDescription
                </div>

                <div class="mt-16 grid grid-cols-2 gap-8 border-t border-[#1A1A1A] pt-12">
                    <div>
                        <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Durata</span>
                        <div class="flex items-center gap-3 text-white">
                            <span class="material-symbols-outlined text-primary">schedule</span>
                            <span class="text-xl">
                                @if(tour.DurationDays > 0) { <span>@tour.DurationDays Giorni</span> }
                                @if(tour.DurationHours > 0) { <span>@tour.DurationHours Ore</span> }
                            </span>
                        </div>
                    </div>
                    <div>
                        <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Punto di Incontro</span>
                        <div class="flex items-center gap-3 text-white">
                            <span class="material-symbols-outlined text-primary">location_on</span>
                            <span class="text-xl">@tour.MeetingPoint</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="relative">
                <div class="charcoal-border p-4">
                    <img src="@MediaUrlBuilder.Build(tour.ExperienceImageUrl)" alt="Experience" class="w-full h-[600px] object-cover" />
                </div>
                <div class="absolute -bottom-10 -left-10 bg-[#D4AF37] p-12 hidden md:block">
                    <span class="text-black font-bold text-4xl block mb-2">@(tour.Price?.ToString("C") ?? "N/D")</span>
                    <span class="text-black/60 font-bold text-[10px] uppercase tracking-widest">Prezzo a persona</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery -->
    @if (tour.TourGalleryImages.Any())
    {
        <section class="py-32 bg-[#050505]">
            <div class="px-6 md:px-16 max-w-7xl mx-auto">
                <h2 class="text-4xl md:text-5xl font-semibold text-white mb-20 section-title text-center">Galleria</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    @foreach (var img in tour.TourGalleryImages.OrderBy(i => i.SortOrder))
                    {
                        <div class="h-80 overflow-hidden charcoal-border group">
                            <img src="@MediaUrlBuilder.Build(img.ImageUrl)" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <!-- Booking CTA -->
    <section class="py-32 bg-black border-t border-[#1A1A1A]">
        <div class="max-w-4xl mx-auto text-center px-6">
            <h2 class="text-4xl md:text-5xl font-semibold text-white mb-8 section-title">Pronto per l'avventura?</h2>
            <p class="text-xl text-gray-400 mb-12 font-light">Prenota ora il tuo tour personalizzato e vivi un'esperienza indimenticabile.</p>
            <a href="/#booking-form" class="bg-[#D4AF37] text-black px-16 py-6 font-bold uppercase text-sm tracking-[0.3em] hover:scale-105 transition-transform inline-block">Richiedi Informazioni</a>
        </div>
    </section>
}
else
{
    <div class="pt-40 pb-20 text-center">
        <h1 class="text-4xl text-white">Tour non trovato</h1>
        <a asp-action="Tours" class="text-primary mt-8 inline-block">Torna ai tour</a>
    </div>
}
