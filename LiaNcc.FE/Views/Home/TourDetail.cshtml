@model TourDetailViewModel
@{
    ViewData["Title"] = Model.Tour?.Name ?? "Dettaglio Tour";
    Layout = "_Layout";
    var tour = Model.Tour;
    
    // Calcoliamo i posti massimi dinamicamente dal veicolo del tour (default 4 se non specificato)
    int maxSeats = tour?.Vehicle?.Seats ?? 4;
}

@if (tour != null)
{
    <section class="relative h-[70vh] flex items-center justify-center text-center px-6 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img alt="@tour.Name" class="w-full h-full object-cover cinematic-img" src="@MediaUrlBuilder.Build(tour.CoverImageUrl)" />
            <div class="absolute inset-0 hero-mask"></div>
        </div>
        <div class="relative z-10 max-w-5xl">
            <span class="font-bold text-primary tracking-[0.4em] uppercase text-xs mb-6 block">@tour.TourCategory?.Name</span>
            <h1 class="text-5xl md:text-7xl font-medium text-white mb-8 tracking-tight uppercase" style="letter-spacing: 5px;">@tour.HeroTitle</h1>
            <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl mx-auto font-light">@tour.HeroSubtitle</p>
        </div>
    </section>

    <section class="py-32 px-6 md:px-16 bg-black">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl md:text-5xl font-semibold text-white mb-12 section-title">L'Esperienza</h2>
                <div class="prose prose-invert prose-lg max-w-none text-gray-400 font-light leading-loose">
                    @tour.ExperienceDescription
                </div>
            </div>
            <div class="relative">
                <div class="charcoal-border p-4">
                    <img src="@MediaUrlBuilder.Build(tour.ExperienceImageUrl)" alt="Experience" class="w-full h-[600px] object-cover" />
                </div>
                <div class="absolute -bottom-10 -left-10 bg-[#D4AF37] p-12 hidden md:block">
                    <span class="text-black font-bold text-4xl block mb-2">
                        @(tour.Price?.ToString("C", new System.Globalization.CultureInfo("it-IT")) ?? "N/D")
                    </span>
                    <span class="text-black/60 font-bold text-[10px] uppercase tracking-widest">Prezzo a persona</span>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-black border-t border-[#1A1A1A]">
        <div class="max-w-7xl mx-auto px-6 md:px-16">
            <h2 class="text-white text-xl font-bold uppercase tracking-widest mb-10">
                Dettagli del viaggio
                <span class="block w-12 h-1 bg-[#D4AF37] mt-4"></span>
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="border border-[#1A1A1A] p-10 flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">schedule</span>
                    <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Durata</span>
                    <span class="text-white text-sm">
                        @if (tour.DurationDays > 0)
                        {
                            <span>@tour.DurationDays Giorni</span>
                        }
                        @if (tour.DurationHours > 0)
                        {
                            <span>@tour.DurationHours Ore</span>
                        }
                        @if (tour.DurationDays == 0 && tour.DurationHours == 0)
                        {
                            <span>Intera Giornata</span>
                        }
                    </span>
                </div>

                <div class="border border-[#1A1A1A] p-10 flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">location_on</span>
                    <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Meeting Point</span>
                    <span class="text-white text-sm">@(tour.MeetingPoint ?? "Pick-up presso Hotel o Residenza Privata")</span>
                </div>

                <div class="border border-[#1A1A1A] p-10 flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">directions_car</span>
                    <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Veicoli</span>
                    <span class="text-white text-sm">
                        @(tour.Vehicle?.Title ?? "Mercedes-Benz Classe S o V-Class Luxury")
                    </span>
                </div>
            </div>
        </div>
    </section>

    @if (tour.TourGalleryImages != null && tour.TourGalleryImages.Any())
    {
        var images = tour.TourGalleryImages.OrderBy(i => i.SortOrder).ToList();
        <section class="py-32 bg-[#050505]">
            <div class="px-6 md:px-16 max-w-7xl mx-auto">
                <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-2">Portfolio Visivo</span>
                <h2 class="text-white text-2xl font-bold uppercase tracking-widest mb-10">
                    Galleria Emozionale
                    <span class="block w-12 h-1 bg-[#D4AF37] mt-4"></span>
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        var colSpan = (i % 4 == 0 || i % 4 == 3) ? "md:col-span-8" : "md:col-span-4";

                        <div class="@colSpan h-80 overflow-hidden charcoal-border">
                            <img src="@MediaUrlBuilder.Build(images[i].ImageUrl)" class="w-full h-full object-cover" />
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <section id="reservations" class="py-32 px-6 md:px-16">
        <div class="max-w-4xl mx-auto">
            <div class="text-left mb-12">
                <h2 class="text-4xl font-semibold text-white mb-4 section-title text-[24px]">Richiesta Prenotazione</h2>
                <p class="text-gray-400 font-light text-[15px]">Compila il modulo per ricevere un preventivo personalizzato immediato.</p>
            </div>

            <div class="bg-black p-8 md:p-20 relative charcoal-border mt-16">

                <form id="tourBookingForm" class="space-y-10">
                    <input type="hidden" name="TourId" value="@tour.Id" />
                    @if (tour.Vehicle != null)
                    {
                        <input type="hidden" name="VehicleId" value="@tour.Vehicle.Id" />
                    }
                    @Html.AntiForgeryToken()

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-2 flex flex-col">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
                            <input name="FullName" type="text" placeholder="Mario Rossi" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors" required />
                        </div>

                        <div class="space-y-2 flex flex-col">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
                            <input name="Email" type="email" placeholder="mario@esempio.it" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors" required />
                        </div>
                    </div>

                    <div class="space-y-2 flex flex-col">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Telefono <span class="text-gray-500 normal-case tracking-normal">(opzionale)</span></label>
                        <input name="Phone" type="tel" placeholder="+39 333 1234567" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors" />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-2 flex flex-col relative z-0">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data Desiderata</label>
                            <input type="text" name="ServiceDateStr" id="custom-date-picker" placeholder="gg/mm/aaaa" class="luxury-datepicker w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors cursor-pointer outline-none" required />
                            <span class="material-symbols-outlined absolute right-0 bottom-4 text-gray-500 pointer-events-none">calendar_today</span>
                        </div>

                        <div class="space-y-2 relative flex flex-col w-full z-50">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Numero Ospiti</label>
                            
                            <select id="desktop-guests-select" class="hidden md:block w-full truncate bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-gray-500 py-4 pr-10 transition-all cursor-pointer outline-none appearance-none !bg-none" style="-webkit-appearance: none; -moz-appearance: none; appearance: none; background-image: none !important; color-scheme: dark;">
                                <option class="bg-black text-gray-500" value="" hidden selected>Seleziona numero ospiti</option>
                                @for (int i = 1; i <= maxSeats; i++)
                                {
                                    <option class="bg-black text-[#D4AF37]" value="@i">@i @(i == 1 ? "Persona" : "Persone")</option>
                                }
                            </select>
                            <span class="hidden md:block material-symbols-outlined absolute right-0 bottom-4 text-[#D4AF37] pointer-events-none">expand_more</span>

                            <div class="block md:hidden relative w-full">
                                <input type="hidden" id="mobile-guests-input" />
                                <div id="guests-btn" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] py-4 pr-10 text-gray-500 font-light text-[15px] cursor-pointer flex justify-between items-center outline-none">
                                    <span id="guests-text" class="truncate text-gray-500">Seleziona numero ospiti</span>
                                    <span class="material-symbols-outlined absolute right-0 bottom-4 text-[#D4AF37] pointer-events-none">expand_more</span>
                                </div>
                                <ul id="guests-menu" class="hidden absolute top-[100%] left-0 w-full bg-[#050505] border border-[#1A1A1A] shadow-2xl m-0 p-0 list-none max-h-64 overflow-y-auto">
                                    @for (int i = 1; i <= maxSeats; i++)
                                    {
                                        <li class="px-4 py-4 text-white hover:bg-[#D4AF37] hover:text-black cursor-pointer transition-colors text-[15px] font-light border-b border-[#1A1A1A]" data-value="@i">@i @(i == 1 ? "Persona" : "Persone")</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2 flex flex-col">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Note Aggiuntive <span class="text-gray-500 normal-case tracking-normal">(opzionale)</span></label>
                        <textarea name="Message" placeholder="Indica eventuali richieste particolari..." rows="3" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors resize-none"></textarea>
                    </div>

                    <button type="submit" class="w-full py-6 bg-[#D4AF37] text-black font-bold uppercase text-[12px] tracking-[0.3em] hover:bg-[#E5C158] transition-all flex items-center justify-center">
                        Invia Richiesta di Prenotazione
                    </button>
                    
                    <div id="tour-booking-message" class="hidden mt-4 p-4 text-center font-bold"></div>
                </form>
            </div>
        </div>
    </section>

    @section Scripts {
        <script>
            function clearTourBookingForm() {
                const form = document.getElementById('tourBookingForm');
                const dateInput = document.getElementById('custom-date-picker');
                const desktopSelect = document.getElementById('desktop-guests-select');
                const guestsText = document.getElementById('guests-text');
                const mobileInput = document.getElementById('mobile-guests-input');

                if (form) form.reset();
                if (dateInput && dateInput._flatpickr) dateInput._flatpickr.clear();

                if (desktopSelect) {
                    desktopSelect.selectedIndex = 0;
                    desktopSelect.classList.remove('text-white');
                    desktopSelect.classList.add('text-gray-500');
                }

                if (guestsText && mobileInput) {
                    guestsText.innerText = "Seleziona numero ospiti";
                    guestsText.classList.remove('text-white');
                    guestsText.classList.add('text-gray-500');
                    mobileInput.value = "";
                }
            }

            document.addEventListener('DOMContentLoaded', function() {
                const dateInput = document.getElementById('custom-date-picker');
                if (dateInput) {
                    flatpickr(dateInput, { locale: "it", dateFormat: "d/m/Y", minDate: "today", disableMobile: true });
                }

                const desktopSelect = document.getElementById('desktop-guests-select');
                if (desktopSelect) {
                    desktopSelect.addEventListener('change', function() {
                        this.classList.remove('text-gray-500');
                        this.classList.add('text-white');
                    });
                }

                const btn = document.getElementById('guests-btn');
                const menu = document.getElementById('guests-menu');
                const text = document.getElementById('guests-text');
                const mobileInput = document.getElementById('mobile-guests-input');

                if (btn && menu) {
                    const options = menu.querySelectorAll('li');

                    btn.addEventListener('click', function(e) {
                        e.preventDefault(); e.stopPropagation(); menu.classList.toggle('hidden');
                    });

                    options.forEach(option => {
                        option.addEventListener('click', function(e) {
                            e.stopPropagation();
                            mobileInput.value = this.getAttribute('data-value');
                            text.innerText = this.innerText;
                            text.classList.remove('text-gray-500');
                            text.classList.add('text-white');
                            menu.classList.add('hidden');
                        });
                    });

                    document.addEventListener('click', function(e) {
                        if (!btn.contains(e.target) && !menu.contains(e.target)) menu.classList.add('hidden');
                    });
                }

                const form = document.getElementById('tourBookingForm');
                if (form) {
                    form.addEventListener('submit', async function(e) {
                        e.preventDefault();
                        
                        const isDesktop = window.innerWidth >= 768;
                        const finalGuestsValue = isDesktop ? desktopSelect.value : mobileInput.value;

                        if (!finalGuestsValue) {
                            alert("Seleziona il numero di ospiti.");
                            return;
                        }

                        const messageDiv = document.getElementById('tour-booking-message');
                        const submitBtn = form.querySelector('button[type="submit"]');
                        const originalText = submitBtn.innerHTML;
                        
                        submitBtn.innerHTML = `<svg class="animate-spin inline-block mr-2 h-4 w-4 text-black" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> INVIO IN CORSO...`;
                        submitBtn.disabled = true;
                        submitBtn.classList.add('opacity-80', 'cursor-not-allowed');

                        const formData = new FormData(form);
                        const params = new URLSearchParams();
                        
                        params.append('SourcePage', 'Dettaglio Tour: @tour.Name');
                        params.append('FullName', formData.get('FullName'));
                        params.append('Email', formData.get('Email'));
                        params.append('MaxSeats', finalGuestsValue);

                        const phone = formData.get('Phone');
                        if (phone && phone.trim() !== '') params.append('Phone', phone);

                        const message = formData.get('Message');
                        if (message && message.trim() !== '') params.append('Message', message);

                        const tourId = formData.get('TourId');
                        if (tourId && tourId.trim() !== '') params.append('TourId', tourId);

                        const vehicleId = formData.get('VehicleId');
                        if (vehicleId && vehicleId.trim() !== '') params.append('VehicleId', vehicleId);

                        const dateStr = formData.get('ServiceDateStr');
                        if (dateStr && dateStr.trim() !== '') {
                            const parts = dateStr.split('/');
                            if (parts.length === 3) params.append('ServiceDate', `${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
                        }

                        const token = formData.get('__RequestVerificationToken');
                        if (token) params.append('__RequestVerificationToken', token);

                        try {
                            const response = await fetch('/Bookings/Create', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: params.toString()
                            });
                            
                            const result = await response.json();
                            
                            if (response.ok && result.success) {
                                messageDiv.textContent = result.message || "Richiesta inviata con successo!";
                                messageDiv.classList.remove('hidden', 'text-red-500');
                                messageDiv.classList.add('text-green-500');
                                clearTourBookingForm();
                                setTimeout(() => { messageDiv.classList.add('hidden'); messageDiv.textContent = ''; }, 5000);
                            } else {
                                throw new Error(result.message || 'Errore server');
                            }
                        } catch (error) {
                            console.error('Error:', error);
                            messageDiv.textContent = "Errore durante l'invio della prenotazione. Riprova.";
                            messageDiv.classList.remove('hidden', 'text-green-500');
                            messageDiv.classList.add('text-red-500');
                        } finally {
                            submitBtn.innerHTML = originalText;
                            submitBtn.disabled = false;
                            submitBtn.classList.remove('opacity-80', 'cursor-not-allowed');
                        }
                    });
                }
            });
        </script>
    }
}
else
{
    <div class="pt-40 pb-20 text-center">
        <h1 class="text-4xl text-white">Tour non trovato</h1>
        <a asp-action="Tours" class="text-primary mt-8 inline-block">Torna ai tour</a>
    </div>
}