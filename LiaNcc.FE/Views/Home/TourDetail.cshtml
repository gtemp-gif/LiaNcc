@using LiaNcc.FE.Services
@model LiaNcc.FE.Models.ViewModels.TourDetailViewModel
@inject IMediaUrlBuilder MediaUrlBuilder
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@{
    ViewData["Title"] = Model.Tour?.Name ?? "Dettaglio Tour";
}

<!-- Hero Section -->
<section class="relative h-screen w-full overflow-hidden flex items-center justify-center text-center">
<div class="absolute inset-0 z-0">
@if(!string.IsNullOrEmpty(Model.Tour?.CoverImageUrl))
{
    <img alt="@Model.Tour.Name" class="w-full h-full object-cover cinematic-img" src="@MediaUrlBuilder.Build(Model.Tour.CoverImageUrl)"/>
}
<div class="absolute inset-0 hero-mask"></div>
</div>
<div class="relative z-10 max-w-5xl px-6">
<span class="font-bold text-primary tracking-[0.4em] uppercase text-xs mb-6 block">@(Model.Tour?.HeroSubtitle ?? "Esclusività Mediterranea")</span>
<h1 class="text-4xl md:text-6xl font-medium text-white mb-8 tracking-tight uppercase" style="letter-spacing: 4px;">@Html.Raw(Model.Tour?.HeroTitle ?? Model.Tour?.Name)</h1>
<div class="w-24 h-1 bg-[#D4AF37] mx-auto"></div>
</div>
</section>
<main class="max-w-7xl mx-auto px-6 md:px-16">
<!-- L'Esperienza -->
<section class="py-32 grid md:grid-cols-2 gap-16 items-center">
<div class="space-y-10">
<div class="text-left">
<h2 class="text-4xl font-semibold text-white mb-4 section-title text-[24px]">L'Esperienza</h2>
<div class="w-16 h-1 bg-[#D4AF37]"></div>
</div>
<div class="space-y-6 text-gray-400 font-light text-[15px] leading-relaxed">
    @Html.Raw(Model.Tour?.ExperienceDescription ?? Model.Tour?.Description)
</div>
</div>
<div class="charcoal-border p-1 hover:border-[#D4AF37] transition-all duration-700 bg-black">
    @if(!string.IsNullOrEmpty(Model.Tour?.ExperienceImageUrl))
    {
        <img alt="@Model.Tour.Name" class="w-full h-[500px] object-cover" src="@MediaUrlBuilder.Build(Model.Tour.ExperienceImageUrl)"/>
    }
</div>
</section>
<!-- Galleria Emozionale (Bento Grid Style) -->
@if(Model.Tour?.TourGalleryImages != null && Model.Tour.TourGalleryImages.Any())
{
    <section class="py-32">
        <div class="text-left mb-16">
            <span class="font-bold text-primary tracking-[0.3em] uppercase text-[10px] mb-2 block">Portfolio Visivo</span>
            <h2 class="text-4xl font-semibold text-white section-title text-[24px]">Galleria Emozionale</h2>
            <div class="w-16 h-1 bg-[#D4AF37] mt-4"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:h-[800px]">
            @{
                var index = 0;
                foreach(var img in Model.Tour.TourGalleryImages.OrderBy(i => i.SortOrder))
                {
                    var colClass = index % 4 == 0 || index % 4 == 3 ? "md:col-span-8" : "md:col-span-4";
                    <div class="@colClass relative overflow-hidden charcoal-border group">
                        <img alt="@Model.Tour.Name" class="w-full h-full object-cover hover:scale-105 transition-all duration-1000" src="@MediaUrlBuilder.Build(img.ImageUrl)"/>
                    </div>
                    index++;
                }
            }
        </div>
    </section>
}
<!-- Dettagli del Viaggio -->
<section class="py-32">
<div class="text-left mb-16">
<h2 class="text-4xl font-semibold text-white section-title text-[24px]">Dettagli del Viaggio</h2>
<div class="w-16 h-1 bg-[#D4AF37] mt-4"></div>
</div>
<div class="grid md:grid-cols-3 gap-8">
    <div class="p-10 charcoal-border bg-black text-center space-y-6 hover:border-[#D4AF37] transition-all duration-500">
        <span class="material-symbols-outlined text-[#D4AF37] text-5xl">schedule</span>
        <h3 class="text-[10px] font-bold text-white uppercase tracking-[0.3em]">Durata</h3>
        <p class="text-gray-400 font-light text-[15px]">@(Model.Tour?.DurationDays > 0 ? $"{Model.Tour.DurationDays} Giorni " : "")@(Model.Tour?.DurationHours > 0 ? $"{Model.Tour.DurationHours} Ore" : "")</p>
    </div>
    <div class="p-10 charcoal-border bg-black text-center space-y-6 hover:border-[#D4AF37] transition-all duration-500">
        <span class="material-symbols-outlined text-[#D4AF37] text-5xl">location_on</span>
        <h3 class="text-[10px] font-bold text-white uppercase tracking-[0.3em]">Meeting Point</h3>
        <p class="text-gray-400 font-light text-[15px]">@(Model.Tour?.MeetingPoint ?? "Pick-up presso Hotel o Residenza Privata")</p>
    </div>
    <div class="p-10 charcoal-border bg-black text-center space-y-6 hover:border-[#D4AF37] transition-all duration-500">
        <span class="material-symbols-outlined text-[#D4AF37] text-5xl">directions_car</span>
        <h3 class="text-[10px] font-bold text-white uppercase tracking-[0.3em]">Veicoli</h3>
        <p class="text-gray-400 font-light text-[15px]">@(Model.Tour?.Vehicle?.Name ?? "Mercedes-Benz Classe S o V-Class Luxury")</p>
    </div>
</div>
</section>
<!-- Richiesta Prenotazione -->
<section class="py-32" id="reservations">
<div class="max-w-4xl mx-auto">
<div class="text-left mb-12">
<h2 class="text-4xl font-semibold text-white mb-4 section-title text-[24px]">Richiesta Prenotazione VIP</h2>
<p class="text-gray-400 font-light text-[15px]">Compila il modulo per ricevere un preventivo personalizzato immediato.</p>
</div>
<div class="bg-black p-8 md:p-20 relative charcoal-border">
<form class="space-y-12">
<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
<div class="space-y-2">
<label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
<input class="w-full input-underline text-white py-4 font-light text-[15px]" placeholder="Mario Rossi" type="text"/>
</div>
<div class="space-y-2">
<label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
<input class="w-full input-underline text-white py-4 font-light text-[15px]" placeholder="mario@esempio.it" type="email"/>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
<div class="space-y-2">
<label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data Desiderata</label>
<input class="w-full input-underline text-white py-4 font-light text-[15px] [color-scheme:dark]" type="date"/>
</div>
<div class="space-y-2">
<label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Numero Ospiti</label>
<select class="w-full input-underline text-white py-4 font-light text-[15px] appearance-none cursor-pointer">
<option class="bg-black">1 - 2 Persone</option>
<option class="bg-black">3 - 5 Persone</option>
<option class="bg-black">Privato Exclusive</option>
</select>
</div>
</div>
<div class="space-y-2">
<label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Preferenze Speciali</label>
<textarea class="w-full input-underline text-white py-4 font-light text-[15px]" placeholder="Indica eventuali richieste alimentari, preferenze musicali o altre esigenze speciali..." rows="4"></textarea>
</div>
<button class="w-full py-6 gold-bg text-black font-bold uppercase tracking-[0.2em] hover:bg-[#E5C158] transition-colors mt-8 text-[12px]" type="submit">INVIA RICHIESTA</button>
</form>
</div>
</div>
</section>
</main>
