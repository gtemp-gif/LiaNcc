@model TourDetailViewModel
@{
    ViewData["Title"] = Model.Tour?.Name ?? "Dettaglio Tour";
    Layout = "_Layout";
    var tour = Model.Tour;
}

@if (tour != null)
{
    <section class="relative h-[70vh] flex items-center justify-center text-center px-6 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img alt="@tour.Name" class="w-full h-full object-cover cinematic-img" src="@MediaUrlBuilder.Build(tour.CoverImageUrl)" />
            <div class="absolute inset-0 hero-mask"></div>
        </div>
        <div class="relative z-10 max-w-5xl">
            <span class="font-bold text-primary tracking-[0.4em] uppercase text-xs mb-6 block">@tour.TourCategory?.Name</span>
            <h1 class="text-5xl md:text-7xl font-medium text-white mb-8 tracking-tight uppercase" style="letter-spacing: 5px;">@tour.HeroTitle</h1>
            <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl mx-auto font-light">@tour.HeroSubtitle</p>
        </div>
    </section>

    <section class="py-32 px-6 md:px-16 bg-black">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl md:text-5xl font-semibold text-white mb-12 section-title">L'Esperienza</h2>
                <div class="prose prose-invert prose-lg max-w-none text-gray-400 font-light leading-loose">
                    @tour.ExperienceDescription
                </div>
            </div>
            <div class="relative">
                <div class="charcoal-border p-4">
                    <img src="@MediaUrlBuilder.Build(tour.ExperienceImageUrl)" alt="Experience" class="w-full h-[600px] object-cover" />
                </div>
                <div class="absolute -bottom-10 -left-10 bg-[#D4AF37] p-12 hidden md:block">
                    <span class="text-black font-bold text-4xl block mb-2">
                        @(tour.Price?.ToString("C", new System.Globalization.CultureInfo("it-IT")) ?? "N/D")
                    </span>
                    <span class="text-black/60 font-bold text-[10px] uppercase tracking-widest">Prezzo a persona</span>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-black border-t border-[#1A1A1A]">
        <div class="max-w-7xl mx-auto px-6 md:px-16">
            <h2 class="text-white text-xl font-bold uppercase tracking-widest mb-10">
                Dettagli del viaggio
                <span class="block w-12 h-1 bg-[#D4AF37] mt-4"></span>
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="border border-[#1A1A1A] p-10 flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">schedule</span>
                    <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Durata</span>
                    <span class="text-white text-sm">
                        @if (tour.DurationDays > 0)
                        {
                            <span>@tour.DurationDays Giorni</span>
                        }
                        @if (tour.DurationHours > 0)
                        {
                            <span>@tour.DurationHours Ore</span>
                        }
                        @if (tour.DurationDays == 0 && tour.DurationHours == 0)
                        {
                            <span>Intera Giornata</span>
                        }
                    </span>
                </div>

                <div class="border border-[#1A1A1A] p-10 flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">location_on</span>
                    <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Meeting Point</span>
                    <span class="text-white text-sm">@(tour.MeetingPoint ?? "Pick-up presso Hotel o Residenza Privata")</span>
                </div>

                <div class="border border-[#1A1A1A] p-10 flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">directions_car</span>
                    <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-4">Veicoli</span>
                    <span class="text-white text-sm">
                        @(tour.Vehicle?.Title ?? "Mercedes-Benz Classe S o V-Class Luxury")
                    </span>
                </div>
            </div>
        </div>
    </section>

    @if (tour.TourGalleryImages != null && tour.TourGalleryImages.Any())
    {
        var images = tour.TourGalleryImages.OrderBy(i => i.SortOrder).ToList();
        <section class="py-32 bg-[#050505]">
            <div class="px-6 md:px-16 max-w-7xl mx-auto">
                <span class="text-[#D4AF37] font-bold text-[10px] uppercase tracking-widest block mb-2">Portfolio Visivo</span>
                <h2 class="text-white text-2xl font-bold uppercase tracking-widest mb-10">
                    Galleria Emozionale
                    <span class="block w-12 h-1 bg-[#D4AF37] mt-4"></span>
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        var colSpan = (i % 4 == 0 || i % 4 == 3) ? "md:col-span-8" : "md:col-span-4";

                        <div class="@colSpan h-80 overflow-hidden charcoal-border">
                            <img src="@MediaUrlBuilder.Build(images[i].ImageUrl)" class="w-full h-full object-cover" />
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <section id="reservations" class="py-32">
        <div class="max-w-4xl mx-auto">
            <div class="text-left mb-12">
                <h2 class="text-4xl font-semibold text-white mb-4 section-title text-[24px]">Richiesta Prenotazione VIP</h2>
                <p class="text-gray-400 font-light text-[15px]">Compila il modulo per ricevere un preventivo personalizzato immediato.</p>
            </div>

            <div class="bg-black p-8 md:p-20 relative charcoal-border mt-16">

                <form action="/tour/book" method="POST" class="space-y-12">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-2 flex flex-col">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
                            <input type="text" placeholder="Mario Rossi" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors" required />
                        </div>

                        <div class="space-y-2 flex flex-col">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
                            <input type="email" placeholder="mario@esempio.it" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors" required />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-2 flex flex-col relative">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data Desiderata</label>
                            <input type="text" placeholder="gg/mm/aaaa" class="luxury-datepicker w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors cursor-pointer" required />
                            <span class="material-symbols-outlined absolute right-0 bottom-4 text-gray-500 pointer-events-none">calendar_today</span>
                        </div>

                        <div class="space-y-2 flex flex-col relative">
                            <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Numero Ospiti</label>
                            <select style="-webkit-appearance: none; -moz-appearance: none; appearance: none; background-image: none !important; color-scheme: dark;" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white py-4 pr-10 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors cursor-pointer outline-none" required>
                                <option class="bg-black text-gray-500" value="" disabled selected>Seleziona numero ospiti</option>
                                <option class="bg-black text-[#D4AF37]" value="1">1 Persona</option>
                                <option class="bg-black text-[#D4AF37]" value="2">2 Persone</option>
                                <option class="bg-black text-[#D4AF37]" value="3">3 - 5 Persone</option>
                                <option class="bg-black text-[#D4AF37]" value="4">Privato Exclusive</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-0 bottom-4 text-[#D4AF37] pointer-events-none">expand_more</span>
                        </div>
                    </div>

                    <div class="space-y-2 flex flex-col">
                        <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Note Aggiuntive (Discrezione Garantita)</label>
                        <textarea placeholder="Indica eventuali richieste particolari..." rows="3" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] text-white placeholder-gray-500 py-4 font-light text-[15px] focus:ring-0 focus:border-[#D4AF37] transition-colors resize-none"></textarea>
                    </div>

                    <button type="submit" class="w-full py-6 bg-[#D4AF37] text-black font-bold uppercase text-[12px] tracking-[0.3em] hover:bg-[#E5C158] transition-all">
                        Invia Richiesta di Prenotazione
                    </button>
                </form>
            </div>
        </div>
    </section>
}
else
{
    <div class="pt-40 pb-20 text-center">
        <h1 class="text-4xl text-white">Tour non trovato</h1>
        <a asp-action="Tours" class="text-primary mt-8 inline-block">Torna ai tour</a>
    </div>
}