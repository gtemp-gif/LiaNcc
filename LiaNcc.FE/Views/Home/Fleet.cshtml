@model FleetViewModel
@{
    ViewData["Title"] = "La Nostra Flotta";
    Layout = "_Layout";
}

<style>
    .luxury-gradient-bg {
        background: radial-gradient(circle at 50% -20%, #1A1A1A 0%, #000000 100%);
    }

    .vehicle-glow {
        filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.15));
    }

    .modal-overlay {
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
    }
</style>

<main class="luxury-gradient-bg pt-32">
    <section class="px-6 md:px-12 py-24 max-w-screen-2xl mx-auto text-center">
        <h1 class="section-title text-4xl md:text-5xl text-white mb-6 uppercase tracking-[3px] font-semibold">LA NOSTRA FLOTTA</h1>
        <p class="font-light text-lg text-[#d0c5af] max-w-2xl mx-auto opacity-80">
            Sperimenta l'eccellenza del servizio chauffeur italiano con la nostra selezione curata di veicoli prestigiosi, progettati per il massimo del comfort e dello stile.
        </p>
        <div class="w-24 h-px bg-[#D4AF37] mx-auto mt-12 opacity-50"></div>
    </section>

    <section class="px-6 md:px-12 pb-32 max-w-screen-2xl mx-auto space-y-48">
        
        @{
            int index = 0;
        }
        @foreach (var vehicle in Model.Vehicles)
        {
            var isEven = index % 2 == 0;
            
            var imgOrderClass = isEven ? "" : "order-1 lg:order-2";
            var textOrderClass = isEven ? "" : "order-2 lg:order-1";

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                
                <div class="lg:col-span-7 @imgOrderClass relative group">
                    <div class="absolute inset-0 bg-[#D4AF37]/5 rounded-none blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
                    <img alt="@vehicle.Name" class="w-full h-auto object-cover border border-[#D4AF37]/10 vehicle-glow" src="@MediaUrlBuilder.Build(vehicle.GalleryImages.FirstOrDefault()?.ImageUrl)" />
                    
                    @if (vehicle.IsBookable)
                    {
                        <div class="absolute top-4 right-4 bg-black/80 px-4 py-2 border border-[#D4AF37]">
                            <span class="text-[#D4AF37] font-bold text-[9px] tracking-widest uppercase">PRENOTABILE</span>
                        </div>
                    }
                </div>

                <div class="lg:col-span-5 @textOrderClass space-y-8">
                    <div class="space-y-2">
                        <span class="font-bold text-[#D4AF37] tracking-[0.3em] text-[10px] uppercase">@vehicle.CategoryName</span>
                        <h2 class="text-3xl font-semibold text-white uppercase" style="letter-spacing: 2px;">@vehicle.Name @vehicle.Title</h2>
                    </div>
                    
                    <p class="font-light text-[#d0c5af] leading-relaxed">
                        @vehicle.Description
                    </p>

                    <div class="grid grid-cols-2 gap-8 border-y border-[#D4AF37]/10 py-8">
                        <div class="flex items-center gap-4">
                            <span class="material-symbols-outlined text-[#D4AF37]">person</span>
                            <span class="font-bold text-white text-[10px] uppercase tracking-widest">@vehicle.Seats PASSEGGERI</span>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="material-symbols-outlined text-[#D4AF37]">luggage</span>
                            <span class="font-bold text-white text-[10px] uppercase tracking-widest">@vehicle.Luggages VALIGIE</span>
                        </div>
                        
                        @foreach (var feature in vehicle.Features.Take(2))
                        {
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined text-[#D4AF37]">@feature.Icon</span>
                                <span class="font-bold text-white text-[10px] uppercase tracking-widest">@feature.Name</span>
                            </div>
                        }
                    </div>

                    @if (vehicle.IsBookable)
                    {
                        <button class="w-full py-5 bg-[#D4AF37] text-black font-bold uppercase text-[10px] tracking-widest hover:bg-[#E5C158] transition-all" onclick="openBookingModal('@vehicle.Name', '@vehicle.Id')">
                            PRENOTA ORA
                        </button>
                    }
                    else
                    {
                        <button class="w-full py-5 border border-[#D4AF37] text-[#D4AF37] bg-transparent font-bold uppercase text-[10px] tracking-widest hover:bg-[#D4AF37] hover:text-black transition-all" onclick="openBookingModal('@vehicle.Name', '@vehicle.Id')">
                            CHIEDI INFORMAZIONI
                        </button>
                    }
                </div>
            </div>

            index++;
        }

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-12">
            <div class="bg-[#050505] border border-[#D4AF37]/10 p-10 flex flex-col items-center text-center group hover:border-[#D4AF37]/30 transition-colors">
                <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">verified</span>
                <h4 class="text-xl font-semibold text-white mb-4 uppercase tracking-wider">Puntualità</h4>
                <p class="text-[#d0c5af] text-sm font-light leading-relaxed">Arrivo previsto 15 minuti prima di ogni prelievo programmato.</p>
            </div>
            <div class="bg-[#050505] border border-[#D4AF37]/10 p-10 flex flex-col items-center text-center group hover:border-[#D4AF37]/30 transition-colors">
                <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">security</span>
                <h4 class="text-xl font-semibold text-white mb-4 uppercase tracking-wider">Discrezione</h4>
                <p class="text-[#d0c5af] text-sm font-light leading-relaxed">Chauffeur professionisti addestrati alla riservatezza e alla privacy d'élite.</p>
            </div>
            <div class="bg-[#050505] border border-[#D4AF37]/10 p-10 flex flex-col items-center text-center group hover:border-[#D4AF37]/30 transition-colors">
                <span class="material-symbols-outlined text-[#D4AF37] text-4xl mb-6">build_circle</span>
                <h4 class="text-xl font-semibold text-white mb-4 uppercase tracking-wider">Manutenzione Meticolosa</h4>
                <p class="text-[#d0c5af] text-sm font-light leading-relaxed">Veicoli ispezionati e igienizzati quotidianamente per garantire i massimi standard di sicurezza, estetica e comfort.</p>
            </div>
        </div>
    </section>
</main>

<div class="hidden fixed inset-0 z-[100] modal-overlay flex items-center justify-center px-4 py-8 overflow-y-auto" id="bookingModal">
    <div class="bg-[#050505] border border-[#1A1A1A] w-full max-w-4xl p-8 md:p-12 relative">
        <button class="absolute top-6 right-6 text-[#D4AF37] hover:scale-110 transition-transform" onclick="closeBookingModal()">
            <span class="material-symbols-outlined text-4xl">close</span>
        </button>
        
        <div class="mb-12 text-left">
            <h2 class="section-title text-3xl md:text-4xl text-white mb-2 uppercase tracking-[3px]">Prenotazione VIP</h2>
            <p class="text-gray-400 font-light text-lg">Ricevi un preventivo personalizzato per: <span class="text-[#D4AF37] font-semibold" id="selectedCarName"></span></p>
        </div>
        
        <form id="fleetBookingForm" class="space-y-8">
            <input type="hidden" name="VehicleId" id="modalVehicleId" />
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Nome Completo</label>
                    <input name="FullName" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all placeholder-gray-500" placeholder="Mario Rossi" type="text" required />
                </div>
                <div class="space-y-2">
                    <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Email</label>
                    <input name="Email" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all placeholder-gray-500" placeholder="mario@esempio.it" type="email" required />
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2 relative flex flex-col">
                    <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Data del Servizio</label>
                    <input type="text" name="ServiceDateStr" id="custom-date-picker" placeholder="gg/mm/aaaa" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all placeholder-gray-500 cursor-pointer outline-none" required />
                    <span class="material-symbols-outlined absolute right-0 bottom-4 text-gray-500 pointer-events-none">calendar_today</span>
                </div>
                
                <div class="space-y-2 relative flex flex-col">
                    <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Tipo di Servizio</label>
                    <select name="ServiceTypeId" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 pr-10 transition-all cursor-pointer outline-none" required>
                        <option class="bg-black text-gray-500" value="" disabled selected>Seleziona un servizio...</option>
                        
                        @if (Model.Services != null)
                        {
                            @foreach (var service in Model.Services)
                            {
                                <option class="bg-black text-[#D4AF37]" value="@service.Id">@service.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            
            <div class="space-y-2">
                <label class="font-bold text-[#D4AF37] text-[10px] uppercase tracking-widest">Messaggio / Richieste Speciali</label>
                <textarea name="Message" class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-[#D4AF37] focus:ring-0 text-white py-4 transition-all placeholder-gray-500 resize-none" placeholder="Indica dettagli aggiuntivi..." rows="3"></textarea>
            </div>
            
            <button class="w-full py-6 bg-[#D4AF37] text-black font-bold uppercase text-[12px] tracking-[0.2em] hover:bg-[#E5C158] transition-all mt-8" type="submit">Invia Richiesta di Prenotazione</button>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        flatpickr("#custom-date-picker", {
            locale: "it",
            dateFormat: "d/m/Y",
            minDate: "today",
            disableMobile: "true"
        });

        const form = document.getElementById('fleetBookingForm');
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(form);

            // Format date for the backend if needed
            const dateStr = formData.get('ServiceDateStr');
            if (dateStr) {
                const parts = dateStr.split('/');
                formData.append('ServiceDate', `${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
            }

            try {
                const response = await fetch('/Bookings/Create', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    closeBookingModal();
                    form.reset();
                } else {
                    alert(result.message || "Si è verificato un errore.");
                }
            } catch (error) {
                console.error('Error:', error);
                alert("Errore durante l'invio della prenotazione.");
            }
        });
    });

    function openBookingModal(carName, vehicleId) {
        document.getElementById('selectedCarName').innerText = carName;
        document.getElementById('modalVehicleId').value = vehicleId;
        document.getElementById('bookingModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeBookingModal() {
        document.getElementById('bookingModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    window.onclick = function(event) {
        let modal = document.getElementById('bookingModal');
        if (event.target == modal) {
            closeBookingModal();
        }
    }
</script>
