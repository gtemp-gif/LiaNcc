@model FleetViewModel
@{
    ViewData["Title"] = "La Nostra Flotta";
    Layout = "_Layout";
}

<section class="pt-40 pb-20 px-6 md:px-16 bg-black">
    <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-semibold text-white mb-8 section-title">La Nostra Flotta</h1>
        <p class="text-xl text-gray-400 max-w-3xl mx-auto font-light">Veicoli di lusso, comfort senza compromessi e tecnologia all'avanguardia per ogni vostro spostamento.</p>
    </div>
</section>

<section class="py-20 px-6 md:px-16 bg-[#050505]">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            @foreach (var vehicle in Model.Vehicles)
            {
                <div class="charcoal-border bg-black overflow-hidden group hover:border-[#D4AF37] transition-all duration-500">
                    <div class="relative h-72 overflow-hidden">
                        <img alt="@vehicle.Name" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="@MediaUrlBuilder.Build(vehicle.GalleryImages.FirstOrDefault()?.ImageUrl)" />
                        @if(vehicle.IsBookable) {
                            <div class="absolute top-4 right-4 bg-black/80 px-4 py-2 border border-[#D4AF37]">
                                <span class="text-[#D4AF37] font-bold text-[9px] tracking-widest uppercase">PRENOTABILE</span>
                            </div>
                        }
                    </div>
                    <div class="p-10">
                        <span class="text-[#D4AF37] text-[10px] font-bold tracking-[0.2em] uppercase mb-2 block">@vehicle.CategoryName</span>
                        <h3 class="text-3xl font-semibold mb-4 text-white">@vehicle.Name @vehicle.Title</h3>
                        <p class="text-gray-500 font-light mb-8 leading-relaxed">@vehicle.Description</p>

                        <div class="flex gap-8 border-t border-[#1A1A1A] pt-8 mb-8">
                            <span class="flex items-center gap-3 text-[12px] text-gray-400 font-bold tracking-wider uppercase">
                                <span class="material-symbols-outlined text-primary text-xl">person</span> @vehicle.Seats Posti
                            </span>
                            <span class="flex items-center gap-3 text-[12px] text-gray-400 font-bold tracking-wider uppercase">
                                <span class="material-symbols-outlined text-primary text-xl">luggage</span> @vehicle.Luggages Valigie
                            </span>
                        </div>

                        <div class="flex flex-wrap gap-4 mb-8">
                            @foreach (var feature in vehicle.Features)
                            {
                                <span class="flex items-center gap-2 text-[10px] text-gray-500 font-semibold uppercase tracking-widest bg-[#111] px-3 py-2 rounded">
                                    <span class="material-symbols-outlined text-sm text-primary">@feature.Icon</span> @feature.Name
                                </span>
                            }
                        </div>

                        @if(vehicle.IsBookable) {
                            <a href="/#booking-form" class="w-full btn-secondary text-center">Prenota Questo Veicolo</a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>
