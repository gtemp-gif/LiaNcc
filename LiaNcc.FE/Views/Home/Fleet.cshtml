@using LiaNcc.FE.Services
@model LiaNcc.FE.Models.ViewModels.FleetPageViewModel
@inject IMediaUrlBuilder MediaUrlBuilder
@{
    ViewData["Title"] = "La Nostra Flotta";
    Layout = "_Layout";
    var heroSection = Model.CmsPage?.PageSections?.FirstOrDefault(s => s.Name == "Hero");
}

<main class="luxury-gradient-bg pt-32">
<!-- Hero Section -->
<section class="px-12 py-24 max-w-screen-2xl mx-auto text-center">
<h1 class="section-title text-4xl md:text-5xl text-white mb-6">@(heroSection?.Title ?? "LA NOSTRA FLOTTA")</h1>
<p class="font-light text-lg text-on-surface-variant max-w-2xl mx-auto opacity-80">
    @Html.Raw(heroSection?.Description ?? "Sperimenta l'eccellenza del servizio chauffeur italiano con la nostra selezione curata di veicoli prestigiosi, progettati per il massimo del comfort e dello stile.")
</p>
<div class="w-24 h-px bg-primary mx-auto mt-12 opacity-50"></div>
</section>
<!-- Fleet Grid -->
<section class="px-12 pb-32 max-w-screen-2xl mx-auto space-y-48">
@if(Model.Vehicles != null && Model.Vehicles.Any())
{
    var index = 0;
    foreach(var vehicle in Model.Vehicles)
    {
        var isEven = index % 2 == 0;
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
            @if(isEven)
            {
                <div class="lg:col-span-7 relative group">
                    <div class="absolute inset-0 bg-primary/5 rounded-none blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
                    <img alt="@vehicle.Name" class="w-full h-auto object-cover border border-primary/10 vehicle-glow" src="@MediaUrlBuilder.Build(null)"/>
                </div>
            }
            <div class="lg:col-span-5 space-y-8 @(!isEven ? "lg:order-first lg:col-start-1" : "")">
                <div class="space-y-2">
                    <span class="font-bold text-primary tracking-[0.3em] text-[10px] uppercase">@(vehicle.Title ?? "VEICOLO LUSSO")</span>
                    <h2 class="text-3xl font-semibold text-white uppercase" style="letter-spacing: 2px;">@vehicle.Name</h2>
                </div>
                <p class="font-light text-on-surface-variant leading-relaxed">
                    @Html.Raw(vehicle.Description)
                </p>
                <div class="grid grid-cols-2 gap-8 border-y border-primary/10 py-8">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined text-primary" data-icon="person">person</span>
                        <span class="font-bold text-[10px] uppercase tracking-widest">@vehicle.Seats PASSEGGERI</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined text-primary" data-icon="luggage">luggage</span>
                        <span class="font-bold text-[10px] uppercase tracking-widest">@vehicle.Luggages VALIGIE GRANDI</span>
                    </div>
                    @if(vehicle.VehicleFeatures != null && vehicle.VehicleFeatures.Any())
                    {
                        foreach(var feature in vehicle.VehicleFeatures)
                        {
                            <div class="flex items-center gap-4">
                                @if(!string.IsNullOrEmpty(feature.Icon))
                                {
                                    <span class="material-symbols-outlined text-primary" data-icon="@feature.Icon">@feature.Icon</span>
                                }
                                <span class="font-bold text-[10px] uppercase tracking-widest">@feature.Name</span>
                            </div>
                        }
                    }
                </div>
                @if(vehicle.IsBookable)
                {
                    <button class="w-full py-5 bg-primary text-black font-bold uppercase text-[10px] tracking-widest hover:bg-[#E5C158] transition-all" onclick="openBookingModal('@vehicle.Name')">
                        PRENOTA ORA
                    </button>
                }
            </div>
        </div>
        index++;
    }
}

<!-- Service Details Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="bg-[#050505] border border-primary/10 p-10 flex flex-col items-center text-center group hover:border-primary/30 transition-colors">
<span class="material-symbols-outlined text-primary text-4xl mb-6">verified</span>
<h4 class="text-xl font-semibold text-white mb-4 uppercase tracking-wider">Puntualità</h4>
<p class="text-on-surface-variant text-sm font-light leading-relaxed">Arrivo previsto 15 minuti prima di ogni prelievo programmato.</p>
</div>
<div class="bg-[#050505] border border-primary/10 p-10 flex flex-col items-center text-center group hover:border-primary/30 transition-colors">
<span class="material-symbols-outlined text-primary text-4xl mb-6">security</span>
<h4 class="text-xl font-semibold text-white mb-4 uppercase tracking-wider">Discrezione</h4>
<p class="text-on-surface-variant text-sm font-light leading-relaxed">Chauffeur professionisti addestrati alla riservatezza e alla privacy d'élite.</p>
</div>
<div class="bg-[#050505] border border-primary/10 p-10 flex flex-col items-center text-center group hover:border-primary/30 transition-colors">
<span class="material-symbols-outlined text-primary text-4xl mb-6">build_circle</span>
<h4 class="text-xl font-semibold text-white mb-4 uppercase tracking-wider">Manutenzione Meticolosa</h4>
<p class="text-on-surface-variant text-sm font-light leading-relaxed">Veicoli ispezionati e igienizzati quotidianamente per garantire i massimi standard di sicurezza, estetica e comfort.</p>
</div>
</div>
</section>
</main>

<div class="hidden fixed inset-0 z-[100] modal-overlay flex items-center justify-center px-4 py-8 overflow-y-auto" id="bookingModal">
<div class="bg-[#050505] border border-[#1A1A1A] w-full max-w-4xl p-8 md:p-12 relative">
<button class="absolute top-6 right-6 text-primary hover:scale-110 transition-transform" onclick="closeBookingModal()">
<span class="material-symbols-outlined text-4xl">close</span>
</button>
<div class="mb-12 text-left">
<h2 class="section-title text-3xl md:text-4xl text-white mb-2">Prenotazione VIP</h2>
<p class="text-gray-400 font-light text-lg">Ricevi un preventivo personalizzato per: <span class="text-primary font-semibold" id="selectedCarName"></span></p>
</div>
<form class="space-y-8">
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="space-y-2">
<label class="font-bold text-primary text-[10px] uppercase tracking-widest">Nome Completo</label>
<input class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-primary focus:ring-0 text-white py-4 transition-all" placeholder="Mario Rossi" type="text"/>
</div>
<div class="space-y-2">
<label class="font-bold text-primary text-[10px] uppercase tracking-widest">Email</label>
<input class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-primary focus:ring-0 text-white py-4 transition-all" placeholder="mario@esempio.it" type="email"/>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="space-y-2">
<label class="font-bold text-primary text-[10px] uppercase tracking-widest">Data del Servizio</label>
<input class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-primary focus:ring-0 text-white py-4 transition-all [color-scheme:dark]" type="date"/>
</div>
<div class="space-y-2">
<label class="font-bold text-primary text-[10px] uppercase tracking-widest">Numero Passeggeri</label>
<select class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-primary focus:ring-0 text-white py-4 transition-all appearance-none cursor-pointer">
<option class="bg-black">1 Passeggero</option>
<option class="bg-black">2 Passeggeri</option>
<option class="bg-black">3 Passeggeri</option>
<option class="bg-black">4+ Passeggeri</option>
</select>
</div>
</div>
<div class="space-y-2">
<label class="font-bold text-primary text-[10px] uppercase tracking-widest">Messaggio / Richieste Speciali</label>
<textarea class="w-full bg-transparent border-0 border-b border-[#1A1A1A] focus:border-primary focus:ring-0 text-white py-4 transition-all" placeholder="Indica dettagli aggiuntivi..." rows="3"></textarea>
</div>
<button class="w-full py-6 bg-primary text-black font-bold uppercase text-[12px] tracking-[0.2em] hover:bg-[#E5C158] transition-all mt-8" type="submit">Richiedi Preventivo</button>
</form>
</div>
</div>
<script>
    function openBookingModal(carName) {
        document.getElementById('selectedCarName').textContent = carName;
        document.getElementById('bookingModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeBookingModal() {
        document.getElementById('bookingModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // Chiudi modale cliccando fuori
    document.getElementById('bookingModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeBookingModal();
        }
    });
</script>
